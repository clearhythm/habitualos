{% macro render(categories, highlightNotes=false) %}
<div class="menu-review__categories">
  {% for category in categories %}
  <div class="menu-category">
    <h3 class="menu-category__name">{{ category.name }}</h3>
    <ul class="menu-category__items">
      {% for item in category.items %}
      <li class="menu-item">
        <div class="menu-item__row">
          <span class="menu-item__name">{{ item.name }}</span>
          {% if item.price %}<span class="menu-item__price">${{ item.price }}</span>{% endif %}
        </div>
        {% if item.description %}<p class="menu-item__desc">{{ item.description }}</p>{% endif %}
        {% if item.tags and item.tags.length %}
        <div class="menu-item__tags">
          {% for tag in item.tags %}<span class="menu-item__tag">{{ tag }}</span>{% endfor %}
        </div>
        {% endif %}
        {% if item.notes %}<p class="menu-item__notes{% if highlightNotes %} menu-item__notes--highlight{% endif %}">{{ item.notes }}</p>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}
</div>
{% endmacro %}
