<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "HabitualOS" }}</title>
  <meta name="description" content="An open-source framework for agentic prototyping and a proprietary suite of daily workflow apps. Built and used daily to explore what human-agent collaboration actually looks like in practice.">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="HabitualOS">
  <meta property="og:title" content="{{ ogTitle or title or 'HabitualOS' }}">
  <meta property="og:description" content="An open-source framework for agentic prototyping and a proprietary suite of daily workflow apps. Built and used daily to explore what human-agent collaboration actually looks like in practice.">
  <meta property="og:url" content="https://www.habitualos.com{{ page.url }}">
  <meta property="og:image" content="https://www.habitualos.com/assets/images/og-default.jpg">

  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ ogTitle or title or 'HabitualOS' }}">
  <meta name="twitter:description" content="An open-source framework for agentic prototyping and a proprietary suite of daily workflow apps. Built and used daily to explore what human-agent collaboration actually looks like in practice.">
  <meta name="twitter:image" content="https://www.habitualos.com/assets/images/og-default.jpg">

  <link rel="icon" type="image/png" href="/assets/images/habitualos_vortex2.png">
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
  {% include "nav.njk" %}

  <main class="main">
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container">
      <p class="text-muted">The HabitualOS platform and featured apps are<br class="d-none d-sm-block"> <span style="white-space: nowrap">&copy; 2026 Erik Burns. All rights reserved.</span></p>
      <p class="text-muted"><a href="https://www.linkedin.com/in/erikburns">LinkedIn</a> &middot; <a href="https://erikburns.com">erikburns.com</a></p>
    </div>
  </footer>

  <div id="lightbox" class="lightbox">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" src="" alt="">
  </div>

  <script src="/assets/js/navigation.js"></script>
</body>
</html>
