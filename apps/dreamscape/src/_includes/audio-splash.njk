<div class="audio-splash" id="audio-splash" hidden>
  <div class="audio-splash-inner">
    <svg class="audio-splash-icon" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 28v-6a16 16 0 0 1 32 0v6"/>
      <rect x="4" y="28" width="8" height="12" rx="4"/>
      <rect x="36" y="28" width="8" height="12" rx="4"/>
    </svg>
    <div class="feed-message feed-visible">
      <span class="feed-name">Sound</span>
      <span class="feed-time">Enjoy the full experience</span>
    </div>
    <button class="audio-splash-btn" id="audio-splash-enable">enable</button>
    <button class="audio-splash-skip reflect-pill" id="audio-splash-skip">no thanks</button>
  </div>
</div>
