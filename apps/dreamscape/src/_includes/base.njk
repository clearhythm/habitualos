<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Daily Practice" }}</title>
  <link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/styles/main.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400&display=swap">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <div class="portrait-lock" aria-hidden="true">
    <svg width="60" height="60" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="19" y="14" width="10" height="18" rx="2.5" transform="rotate(-25 24 23)"/>
      <path d="M 24 5 A 19 19 0 1 1 5 24"/>
      <path d="M 1.5 28.5 L 5 24 L 8.5 28.5"/>
    </svg>
    <span>please rotate your device</span>
  </div>

  {% if not noNav %}{% include "nav.njk" %}{% endif %}

  <main class="main">
    {% if noContainer %}
      {{ content | safe }}
    {% else %}
    <div class="container">
      {{ content | safe }}
    </div>
    {% endif %}
  </main>

  {% if not noFooter %}
  <footer class="footer">
    <div class="container">
      <p>Daily Practice &copy; 2026 Erik Burns</p>
    </div>
  </footer>
  {% endif %}
  <script type="module" src="/assets/js/navigation.js"></script>
  {% if not noAudioUnlock %}
  <script type="module" src="/assets/js/audio-unlock.js"></script>
  {% endif %}
  {% if pageScript %}
  <script type="module" src="{{ pageScript }}"></script>
  {% endif %}
  </body>
</html>
