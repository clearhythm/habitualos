{# Celebration overlay — witnessed-by cutscene. Lazy-activated by celebration.js. #}
<div id="celebration-view">

  {# Background birds — small, slow, high in sky #}
  <div class="birds-bg">
    <svg class="bird" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M 0,5 Q 2.5,0 5,5 Q 7.5,0 10,5" stroke="rgba(255,255,255,0.45)" stroke-width="1" fill="none" stroke-linecap="round"/></svg>
    <svg class="bird" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M 0,5 Q 2.5,0 5,5 Q 7.5,0 10,5" stroke="rgba(255,255,255,0.40)" stroke-width="1" fill="none" stroke-linecap="round"/></svg>
