  </div>

  {# Mid birds — medium, moderate speed #}
  <div class="birds-mid">
    <svg class="bird" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M 0,5 Q 2.5,0 5,5 Q 7.5,0 10,5" stroke="rgba(255,255,255,0.60)" stroke-width="1" fill="none" stroke-linecap="round"/></svg>
    <svg class="bird" viewBox="0 0 10 6" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M 0,5 Q 2.5,0 5,5 Q 7.5,0 10,5" stroke="rgba(255,255,255,0.65)" stroke-width="1" fill="none" stroke-linecap="round"/></svg>
