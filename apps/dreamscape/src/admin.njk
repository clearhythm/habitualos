---
layout: admin-base.njk
title: Daily Practice Admin
permalink: /admin/
adminScripts:
  - /assets/js/admin/api.js
  - /assets/js/admin/nav.js
  - /assets/js/admin/unit-tests.js
  - /assets/js/admin/testing.js
  - /assets/js/admin/test-data.js
  - /assets/js/admin/stats.js
  - /assets/js/admin/logs.js
---

<header class="navbar navbar-expand-md navbar-light d-print-none">
  <div class="container-xl">
    <h1 class="navbar-brand mb-0">
      <a href=".">Daily Practice Admin</a>
    </h1>
    <div class="navbar-nav flex-row gap-1 admin-nav-center">
      <a href="#" class="admin-nav-link active" data-view="usage">Usage</a>
      <a href="#" class="admin-nav-link" data-view="testing">Testing</a>
      <a href="#" class="admin-nav-link" data-view="logs">Logs</a>
    </div>
    <div class="navbar-nav flex-row order-md-last">
      <span class="badge bg-green-lt">Zero Trust</span>
    </div>
  </div>
</header>

<div class="page-wrapper">
  <div class="page-body">
    <div class="container-xl">

      <!-- Usage -->
      <div id="view-usage" class="admin-view">
        <div class="row row-deck row-cards">
          <div class="col-12">
            <h2 class="mb-3">Usage</h2>
          </div>

          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Users</h3>
                <div class="card-options">
                  <button class="btn btn-sm btn-outline-secondary" id="refresh-stats">Refresh</button>
                </div>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-vcenter card-table">
                    <thead>
                      <tr>
                        <th>Name</th>
                        <th>User ID</th>
                        <th>Last practiced</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody id="users-table">
                      <tr><td colspan="4" class="text-center text-muted py-3">Loading…</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Recent Sessions</h3>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-vcenter card-table">
                    <thead>
                      <tr>
                        <th>User</th>
                        <th>Started</th>
                        <th>Duration</th>
                        <th>State</th>
                        <th>Note</th>
                      </tr>
                    </thead>
                    <tbody id="sessions-table">
                      <tr><td colspan="5" class="text-center text-muted py-3">Loading…</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Testing -->
      <div id="view-testing" class="admin-view" hidden>
        <div class="row row-deck row-cards">
          <div class="col-12">
            <h2 class="mb-3">Unit Tests</h2>
          </div>
          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">API Endpoints</h3>
                <div class="card-options">
                  <button class="btn btn-sm btn-primary" id="run-tests-btn">Run all tests</button>
                </div>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">
                  Runs live assertions against all API endpoints using test users.
                  Seed scenario B first to ensure notes exist for unlock/read tests.
                </p>
                <div id="test-results" hidden></div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <h2 class="mb-3">Scenarios</h2>
          </div>
          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Seed Test Scenarios</h3>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">
                  Seeds test users into the <code>users</code> collection, creates connections,
                  and sets note/unlock state for <code>u-test-erik</code>.
                </p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                  <button class="btn btn-outline-secondary seed-btn" data-scenario="no-notes">A — No notes</button>
                  <button class="btn btn-outline-warning seed-btn" data-scenario="notes-waiting">B — Notes waiting (locked)</button>
                  <button class="btn btn-outline-success seed-btn" data-scenario="notes-unlocked">C — Notes unlocked</button>
                  <button class="btn btn-outline-info seed-btn" data-scenario="all-caught-up">D — All caught up</button>
                </div>
                <div>
                  <button class="btn btn-outline-danger" id="reset-btn">Reset test data</button>
                </div>
                <div id="seed-status" class="mt-3" hidden></div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Test Users</h3>
              </div>
              <div class="card-body">
                <table class="table table-sm">
                  <thead>
                    <tr><th>ID</th><th>Name</th><th>Role</th></tr>
                  </thead>
                  <tbody id="test-users-table"></tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="col-12">
            <h2 class="mb-3">Test Data</h2>
          </div>

          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Primitives</h3>
              </div>
              <div class="card-body">
                <p class="text-muted small mb-3">
                  One-tap data operations on <code>tu-*</code> test users. Active user is the subject of all actions.
                </p>

                <div class="row g-3">
                  <div class="col-md-6">
                    <label class="form-label">Create test user</label>
                    <div class="input-group">
                      <input type="text" id="new-user-name" class="form-control form-control-sm" placeholder="frank → tu-frank">
                      <button class="btn btn-sm btn-primary" id="create-user-btn">Create</button>
                    </div>
                    <div id="create-user-status" class="form-text mt-1"></div>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label">Active user</label>
                    <div class="input-group">
                      <select id="test-user-select" class="form-select form-select-sm">
                        <option value="">Loading…</option>
                      </select>
                      <button class="btn btn-sm btn-outline-secondary" id="refresh-tu-btn" title="Refresh">↻</button>
                      <button class="btn btn-sm btn-outline-primary" id="sign-in-as-btn">Sign in as</button>
                    </div>
                  </div>

                  <div class="col-12">
                    <label class="form-label">Practices</label>
                    <div class="d-flex gap-2">
                      <button class="btn btn-sm btn-outline-success" id="create-practice-btn">Create practice</button>
                      <button class="btn btn-sm btn-outline-secondary" id="delete-practices-btn">Delete all practices</button>
                    </div>
                    <div id="practice-status" class="form-text mt-1"></div>
                  </div>

                  <div class="col-md-6">
                    <label class="form-label">Connect active ↔ target</label>
                    <div class="input-group">
                      <select id="connect-target-select" class="form-select form-select-sm">
                        <option value="">Select target…</option>
                      </select>
                      <button class="btn btn-sm btn-outline-primary" id="connect-btn">Connect</button>
                    </div>
                    <div id="connect-status" class="form-text mt-1"></div>
                  </div>

                  <div class="col-12 border-top pt-3 mt-1">
                    <label class="form-label text-danger">Danger</label>
                    <div class="d-flex gap-2">
                      <button class="btn btn-sm btn-danger" id="delete-user-btn">Delete active user</button>
                      <button class="btn btn-sm btn-danger" id="nuke-all-btn">Nuke all tu-* users</button>
                    </div>
                    <div id="danger-status" class="form-text mt-1"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Logs -->
      <div id="view-logs" class="admin-view" hidden>
        <div class="row row-deck row-cards">
          <div class="col-12">
            <h2 class="mb-3">API Logs</h2>
          </div>
          <div class="col-12">
            <div class="card">
              <div class="card-header">
                <h3 class="card-title">Recent activity</h3>
                <div class="card-options">
                  <button class="btn btn-sm btn-outline-secondary" id="refresh-logs">Refresh</button>
                </div>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-vcenter card-table">
                    <thead>
                      <tr>
                        <th>Time</th>
                        <th>Action</th>
                        <th>Result</th>
                        <th>Params / Error</th>
                      </tr>
                    </thead>
                    <tbody id="logs-table">
                      <tr><td colspan="4" class="text-center text-muted py-3">Load logs to begin</td></tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
