---
layout: base.njk
title: Wake Lock Test — Dreamscape
pageScript: /assets/js/pages/wakelock-test.js
---

<style>
  .test-card {
    background: var(--color-surface, #1e1b4b);
    border: 1px solid var(--color-border, #2d2a5e);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .track-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .track-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .track-title {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted, #6b7280);
  }

  .track-select {
    width: 100%;
    padding: 0.5rem 0.75rem;
    background: var(--color-surface, #1e1b4b);
    border: 1px solid #6b5ce7;
    border-radius: 6px;
    color: #a78bfa;
    font-size: 0.875rem;
  }

  .file-btn {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    background: rgba(107, 92, 231, 0.2);
    border: 1px solid #6b5ce7;
    border-radius: 6px;
    color: #a78bfa;
    font-size: 0.875rem;
    cursor: pointer;
    text-align: center;
  }

  .file-name {
    font-size: 0.78rem;
    color: var(--color-text-muted, #9ca3af);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .vol-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .vol-row input[type=range] { flex: 1; accent-color: #6b5ce7; }
  .vol-row span { font-size: 0.8rem; color: var(--color-text-muted, #9ca3af); min-width: 2.5rem; text-align: right; }

  .status-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1.25rem 0;
  }

  .status-item { display: flex; flex-direction: column; gap: 0.25rem; }

  .status-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted, #6b7280);
  }

  .status-badge { font-size: 0.9rem; font-weight: 600; padding: 0.25rem 0; }
  .status-ok    { color: #4ade80; }
  .status-warn  { color: #fbbf24; }
  .status-error { color: #f87171; }
  .status-idle  { color: var(--color-text-muted, #6b7280); }

  .timer {
    font-size: 3rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    color: #6b5ce7;
    text-align: center;
    padding: 0.75rem 0;
    letter-spacing: 0.05em;
  }

  .btn-row { display: flex; gap: 1rem; margin-top: 1rem; }

  .btn-primary {
    flex: 1;
    padding: 0.875rem 1.5rem;
    background: #6b5ce7;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-primary:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-secondary {
    flex: 1;
    padding: 0.875rem 1.5rem;
    background: transparent;
    color: var(--color-text-muted, #6b7280);
    border: 1px solid var(--color-border, #2d2a5e);
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
  }

  .btn-secondary:disabled { opacity: 0.4; cursor: not-allowed; }

  .event-log {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--color-text-muted, #9ca3af);
    max-height: 180px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .note {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6b7280);
    padding: 0.75rem 1rem;
    background: rgba(251, 191, 36, 0.08);
    border-left: 3px solid #fbbf24;
    border-radius: 0 6px 6px 0;
    margin-top: 1rem;
  }

  h2 { font-size: 1rem; margin: 0 0 1rem; color: var(--color-text-muted, #9ca3af); font-weight: 500; }
</style>

<h1>Wake Lock Test</h1>
<p style="color: var(--color-text-muted, #6b7280); margin-top: 0.5rem; margin-bottom: 1.5rem;">
  Two-track validation — music + voice with independent volume sliders. Tests the real playback architecture against screen lock.
  <strong style="color: #fff;">Run on your phone.</strong>
</p>

<div class="test-card">
  <div class="track-row">
    <div class="track-block">
      <span class="track-title">Music</span>
      <select id="music-select" class="track-select"></select>
      <span class="status-badge status-idle" id="music-track-status">Loading…</span>
      <div class="vol-row">
        <input type="range" id="music-vol" min="0" max="1" step="0.05" value="0.5">
        <span id="music-vol-label">50%</span>
      </div>
    </div>

    <div class="track-block">
      <span class="track-title">Voice</span>
      <label class="file-btn" for="voice-input">Choose file</label>
      <input type="file" id="voice-input" accept="audio/*" style="display:none">
      <span class="file-name" id="voice-label">No file loaded</span>
      <span class="status-badge status-idle" id="voice-track-status">Idle</span>
      <div class="vol-row">
        <input type="range" id="voice-vol" min="0" max="1" step="0.05" value="0.8">
        <span id="voice-vol-label">80%</span>
      </div>
    </div>
  </div>

  <div class="timer" id="timer">00:00</div>

  <div class="status-grid">
    <div class="status-item">
      <span class="status-label">AudioContext</span>
      <span class="status-badge status-idle" id="ctx-status">Idle</span>
    </div>
    <div class="status-item">
      <span class="status-label">Wake Lock</span>
      <span class="status-badge status-idle" id="wakelock-status">Idle</span>
    </div>
    <div class="status-item">
      <span class="status-label">Resume Count</span>
      <span class="status-badge status-idle" id="resume-count">—</span>
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-primary" id="start-btn" disabled>Start Test</button>
    <button class="btn-secondary" id="stop-btn" disabled>Stop</button>
  </div>

  <div class="note">
    Music loads automatically from bundled assets. Load a voice file from your device to test both layers together.
  </div>
</div>

<div class="test-card">
  <h2>Event Log</h2>
  <div class="event-log" id="event-log"></div>
</div>
