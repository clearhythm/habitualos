---
layout: base.njk
title: Sign In — Daily Practice
permalink: /signin/
pageScript: /assets/js/pages/signin.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">
  <div class="auth-page">

    <div class="circle-header">
      <div id="header-chime-wrap">
        {% include "wind-chime.njk" %}
      </div>
      <div class="feed-message feed-visible">
        <span class="feed-name">Sign In</span>
      </div>
    </div>

    <div class="auth-steps">

      <div class="auth-step" id="step-verify" hidden>
        <p class="feed-time auth-step-label">Signing you in…</p>
      </div>

      <div class="auth-step" id="step-form" hidden>
        <div class="practice-field">
          <input type="email" id="signin-email" class="practice-name-input" placeholder="you@email.com" autocomplete="email" inputmode="email">
          <p class="auth-subtext">Enter the email you signed up with.<br>We'll send you a link to sign in.</p>
        </div>
        <p class="auth-error" id="signin-error" hidden></p>
        <button class="pill" id="signin-btn">send link</button>
        <a href="mailto:erik@habitualos.com?subject=Daily%20Practice%3A%20help%20with%20sign%20in" class="btn-quiet" target="_blank">need help?</a>
      </div>

      <div class="auth-step" id="step-sent" hidden>
        <p class="auth-subtext">We sent a link to <span id="sent-email"></span>.<br>Click the link to sign in to your account.<br>Not there? Check your spam folder.</p>
        <button class="btn-quiet" id="signin-try-another">change or resend</button>
      </div>

    </div>

  </div>
</div>
