      <circle cx="28" cy="60" r="3.5" fill="rgba(255,255,255,0.35)"/>
      <line x1="30" y1="52" x2="28" y2="57" stroke="rgba(255,255,255,0.20)" stroke-width="0.8"/>
    </svg>
    <div class="feed-message feed-visible" id="feed-message">
      <span class="feed-name">Present</span>
      <span class="feed-time">since your last visit</span>
    </div>
    <a href="/practice/" class="practice-pill">practice</a>
  </div>

  <a href="/invite/" class="invite-pill" id="invite-pill" hidden>Invite a friend</a>

</div>

<div class="ambient-player" id="ambient-player">
  <button class="ambient-mute-btn" id="ambient-mute-btn" aria-label="Toggle sound">
    <svg id="icon-sound-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"/>
    </svg>
    <svg id="icon-sound-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
      <line x1="23" y1="9" x2="17" y2="15"/>
      <line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
  </button>
  <input type="range" class="ambient-volume" id="ambient-volume"
         min="0" max="1" step="0.01" value="1" aria-label="Volume">
</div>
