      <line x1="20" y1="10" x2="20" y2="18" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>
      <line x1="30" y1="10" x2="30" y2="22" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>
      <line x1="40" y1="10" x2="40" y2="16" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>
      <line x1="50" y1="10" x2="50" y2="20" stroke="rgba(255,255,255,0.25)" stroke-width="0.8"/>
      <rect x="8"  y="24" width="4" height="22" rx="2" fill="rgba(255,255,255,0.52)"/>
