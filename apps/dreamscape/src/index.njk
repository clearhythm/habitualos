---
layout: base.njk
title: Daily Practice
pageScript: /assets/js/pages/home.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">

  <div class="scene-backdrop" data-tier="0">

    {# Tier 1: celestial — sun, moon, stars #}
    <div class="scene-celestial">
      <div class="scene-sun"></div>
      <div class="scene-moon"></div>
      <div class="scene-stars">
        <svg viewBox="0 0 100 55" preserveAspectRatio="xMidYMin meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="6"  cy="14" r="0.42" fill="white"/>
          <circle cx="14" cy="5"  r="0.50" fill="white"/>
          <circle cx="22" cy="19" r="0.32" fill="white"/>
          <circle cx="31" cy="8"  r="0.45" fill="white"/>
          <circle cx="40" cy="3"  r="0.38" fill="white"/>
          <circle cx="49" cy="13" r="0.42" fill="white"/>
          <circle cx="57" cy="6"  r="0.50" fill="white"/>
          <circle cx="66" cy="17" r="0.30" fill="white"/>
          <circle cx="75" cy="4"  r="0.40" fill="white"/>
          <circle cx="83" cy="11" r="0.36" fill="white"/>
          <circle cx="92" cy="7"  r="0.44" fill="white"/>
          <circle cx="97" cy="18" r="0.30" fill="white"/>
          <circle cx="18" cy="30" r="0.28" fill="white"/>
          <circle cx="44" cy="25" r="0.34" fill="white"/>
          <circle cx="70" cy="28" r="0.28" fill="white"/>
          <circle cx="88" cy="32" r="0.24" fill="white"/>
        </svg>
      </div>
    </div>

    {# Tier 2: mountains — two SVG variants, CSS media query swaps on orientation change.
       Rotating a phone instantly switches between them — no JS or reload needed. #}
    <div class="scene-mountains">

      {# Portrait variant — primary (phone upright). viewBox ~4:3, peaks steep and centered. #}
      <svg class="mountains-portrait" viewBox="0 0 100 75" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polygon points="0,75 0,60 25,54 50,58 75,54 100,60 100,75" fill="#1e3040" opacity="0.35"/>
        <polygon points="0,75 0,54 15,44 30,32 45,42 50,48 55,42 70,32 85,44 100,54 100,75" fill="#1c2e3a" opacity="0.55"/>
        <polygon points="0,75 0,50 10,40 22,26 30,36 38,46 50,52 62,46 70,36 78,26 90,40 100,50 100,75" fill="#1a2a34" opacity="0.80"/>
        <polygon points="0,75 0,52 8,42 18,28 25,8 34,22 42,40 50,56 58,40 66,22 75,8 82,28 92,42 100,52 100,75" fill="#182430"/>
      </svg>

      {# Landscape variant — 2000-unit wide elastic design.
         Peaks at x≈700 and x≈1300 (center). Outer zones (0-500, 1500-2000) are
         gentle slopes that absorb viewport cropping gracefully on any screen width. #}
      <svg class="mountains-landscape" viewBox="0 0 2000 500" preserveAspectRatio="xMidYMax meet" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        {# Furthest ridge — barely perceptible undulation #}
        <polygon points="0,500 0,478 500,464 1000,472 1500,464 2000,478 2000,500" fill="#1e3040" opacity="0.35"/>
        {# Far ridge #}
        <polygon points="0,500 0,462 200,444 420,416 620,374 820,326 1000,432 1180,326 1380,374 1580,416 1800,444 2000,462 2000,500" fill="#1c2e3a" opacity="0.55"/>
        {# Mid ridge #}
        <polygon points="0,500 0,444 150,414 320,376 480,332 620,272 740,196 840,158 900,172 960,210 1000,382 1040,210 1100,172 1160,158 1260,196 1380,272 1520,332 1680,376 1850,414 2000,444 2000,500" fill="#1a2a34" opacity="0.80"/>
        {# Near ridge — long gentle outer slopes, dramatic peaks at x≈700 and x≈1300 #}
        <polygon points="0,500 0,424 100,396 220,362 340,322 460,274 560,218 630,158 680,100 700,62 726,96 760,132 820,98 880,66 940,128 1000,322 1060,128 1120,66 1180,98 1240,132 1274,96 1300,62 1320,100 1370,158 1440,218 1540,274 1660,322 1780,362 1900,396 2000,424 2000,500" fill="#182430"/>
      </svg>

    </div>

    {# Tier 3: water — left-side waterfall + center valley stream (both appear at tier 3) #}
    <div class="scene-river">

      {# Static water bodies — shapes, color, depth #}
      <svg class="scene-river-static" viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        {# Waterfall — left side, narrow cascade from mountain face #}
        <polygon points="12,20 16,20 18,100 10,100" fill="#2a4a60" opacity="0.65"/>
        <polygon points="13,20 15,20 16,100 12,100" fill="#3a5a70" opacity="0.45"/>
        {# Mist pool at waterfall base #}
        <ellipse cx="14" cy="96" rx="8" ry="3" fill="#2a4055" opacity="0.30"/>
        {# Valley stream — starts at center valley (~y58), widens toward viewer #}
        <polygon points="47,58 53,58 60,100 40,100" fill="#1e3040" opacity="0.75"/>
        <polygon points="49,58 51,58 54,100 46,100" fill="#2a4a60" opacity="0.45"/>
      </svg>

      {# Waterfall flow — two identical streak tiles; wrapper translates downward, loops seamlessly #}
      <div class="waterfall-flow">
        <div class="waterfall-flow-inner">
          {%- for _ in [1, 2] %}
          <svg viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="8"  y="0" width="7"  height="100" fill="rgba(180,225,245,0.20)" rx="3"/>
            <rect x="28" y="0" width="4"  height="100" fill="rgba(200,235,255,0.16)"/>
            <rect x="47" y="0" width="9"  height="100" fill="rgba(180,225,245,0.14)" rx="4"/>
            <rect x="68" y="0" width="5"  height="100" fill="rgba(200,235,255,0.22)"/>
            <rect x="82" y="0" width="6"  height="100" fill="rgba(180,225,245,0.17)" rx="2"/>
          </svg>
          {%- endfor %}
        </div>
      </div>

      {# River near-section flow — wavy lines, amplitude decreases toward top (perspective) #}
      <div class="river-flow">
        <div class="river-flow-inner">
          {%- for _ in [1, 2] %}
          <svg viewBox="0 0 100 100" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            {# Bottom (nearest viewer) — most pronounced #}
            <path d="M 0,88 Q 22,79 50,88 Q 78,97 100,88" stroke="rgba(160,210,235,0.34)" stroke-width="1.5" fill="none"/>
            <path d="M 0,74 Q 25,66 50,74 Q 75,82 100,74" stroke="rgba(160,210,235,0.28)" stroke-width="1.2" fill="none"/>
            <path d="M 0,60 Q 28,53 50,60 Q 72,67 100,60" stroke="rgba(160,210,235,0.24)" stroke-width="1.1" fill="none"/>
            {# Middle #}
            <path d="M 0,46 Q 25,40 50,46 Q 75,52 100,46" stroke="rgba(160,210,235,0.20)" stroke-width="0.9" fill="none"/>
            <path d="M 0,32 Q 30,28 50,32 Q 70,36 100,32" stroke="rgba(160,210,235,0.16)" stroke-width="0.8" fill="none"/>
            {# Top (furthest) — barely perceptible #}
            <path d="M 0,18 Q 25,16 50,18 Q 75,20 100,18" stroke="rgba(160,210,235,0.12)" stroke-width="0.7" fill="none"/>
            <path d="M 0,6  Q 25,5  50,6  Q 75,7  100,6"  stroke="rgba(160,210,235,0.08)" stroke-width="0.6" fill="none"/>
          </svg>
          {%- endfor %}
        </div>
      </div>

    </div>

    {# Tier 4: tree — foreground silhouette (uses tree.png; swap for SVG once asset is ready) #}
    <div class="scene-tree">
      <img src="/assets/images/tree.png" alt="">
    </div>

    {# Tier 5: birds — scattered across the upper sky (not tied to tree) #}
    <div class="scene-birds">
      <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        {# Each bird: two arc strokes meeting at a central peak — classic flying silhouette #}
        <path d="M 14,28 Q 16,24 18,28" stroke="rgba(20,30,40,0.75)" stroke-width="0.9" fill="none" stroke-linecap="round"/>
        <path d="M 23,22 Q 25,18 27,22" stroke="rgba(20,30,40,0.70)" stroke-width="0.8" fill="none" stroke-linecap="round"/>
        <path d="M 36,32 Q 38,28 40,32" stroke="rgba(20,30,40,0.65)" stroke-width="0.7" fill="none" stroke-linecap="round"/>
        <path d="M 52,18 Q 54,14 56,18" stroke="rgba(20,30,40,0.75)" stroke-width="0.9" fill="none" stroke-linecap="round"/>
        <path d="M 64,26 Q 66,22 68,26" stroke="rgba(20,30,40,0.60)" stroke-width="0.7" fill="none" stroke-linecap="round"/>
        <path d="M 76,20 Q 78,16 80,20" stroke="rgba(20,30,40,0.70)" stroke-width="0.8" fill="none" stroke-linecap="round"/>
        <path d="M 86,34 Q 88,30 90,34" stroke="rgba(20,30,40,0.55)" stroke-width="0.65" fill="none" stroke-linecap="round"/>
      </svg>
    </div>

  </div>

  <div class="blossom-content">
    <div id="wind-chime">{% svgIcon "chime" %}</div>
    <div class="feed-message feed-visible" id="feed-message">
      <span class="feed-name"></span>
      <span class="feed-time"></span>
    </div>
    <div class="practice-actions" style="visibility:hidden">
      <button class="practice-pill btn-confirmable" id="celebrate-btn" hidden>
        <span class="btn-label">witness</span>
        <span class="btn-label-done" aria-hidden="true">witnessed</span>
      </button>
      <button class="btn-quiet" id="continue-btn" hidden>continue</button>
      <a href="/practice/" class="practice-pill" id="main-action-btn">practice</a>
      <a href="/reflect/" class="btn-quiet reflect-pill" id="reflect-pill" hidden>reflect</a>
      <button class="btn-quiet voice-chime-btn" id="voice-chime-btn" hidden>skip</button>
    </div>
  </div>

  <a href="/invite/" class="invite-pill" id="invite-pill" hidden>Invite a friend</a>

</div>

<div id="witness-notif" class="witness-notif"></div>

{% include "ambient-player.njk" %}
{% include "dev-toolbar.njk" %}
