---
layout: base.njk
title: Daily Practice
pageScript: /assets/js/pages/home.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">

  <div class="blossom-content">
    <div id="wind-chime">{% include "wind-chime.njk" %}</div>
    <div class="feed-message feed-visible" id="feed-message">
      <span class="feed-name"></span>
      <span class="feed-time"></span>
    </div>
    <div class="practice-actions">
      <a href="/practice/" class="practice-pill" id="main-action-btn">practice</a>
      <button class="practice-pill" id="celebrate-btn" hidden>
        <span class="witness-label">witness</span>
        <span class="witness-label-done" aria-hidden="true">witnessed</span>
      </button>
      <a href="/reflect/" class="btn-quiet reflect-pill" id="reflect-pill" data-auth-only hidden>reflect</a>
      <button class="btn-quiet" id="continue-btn" hidden>continue</button>
      <a href="/circle/" class="btn-quiet voice-chime-btn" id="voice-chime-btn" hidden>speak</a>
    </div>
  </div>

  <a href="/invite/" class="invite-pill" id="invite-pill" hidden>Invite a friend</a>

</div>

{% include "ambient-player.njk" %}
