---
layout: base.njk
title: Practice — Daily Practice
permalink: /practice/timer/
pageScript: /assets/js/pages/practice-timer.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">

  <div class="timer-modal" id="timer-modal">
    <div class="practice-label" id="practice-label"></div>

    <div id="timer-view">
      <div class="timer-complete-label" id="complete-label" hidden>You completed</div>
      <div class="timer" id="timer">00:00</div>

      <button class="timer-circle-btn" id="pause-btn" aria-label="Pause" data-tooltip="pause practice">
        <svg id="icon-pause" viewBox="0 0 64 64" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="32" cy="32" r="26"/>
          <line x1="26" y1="22" x2="26" y2="42"/>
          <line x1="38" y1="22" x2="38" y2="42"/>
        </svg>
        <svg id="icon-play" viewBox="0 0 64 64" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="32" cy="32" r="26"/>
          <path d="M27 22 L43 32 L27 42 Z"/>
        </svg>
      </button>

      <div class="timer-actions">
        <button class="btn-quiet" id="stop-btn" data-tooltip="save practice">finish</button>
        <button class="btn-quiet timer-discard" id="discard-btn" hidden data-tooltip="cancel practice">discard</button>
      </div>
    </div>

    <div id="note-view" class="note-view" hidden>
      <div class="circle-header">
        <svg viewBox="0 0 96 96" fill="none" stroke="currentColor" stroke-width="3.8"
             stroke-linecap="round" stroke-linejoin="round"
             class="circle-icon circle-icon--lg" aria-hidden="true">
          <path d="M20 76 C16 50 36 20 70 14"/>
          <path d="M20 76 C40 70 62 54 70 14"/>
          <path d="M20 76 C26 58 44 36 62 20"/>
          <path d="M20 76 C30 60 52 42 66 18"/>
          <path d="M20 76 C36 66 56 50 68 16"/>
        </svg>
        <div class="feed-message feed-visible">
          <span class="feed-name">Reflect</span>
        </div>
      </div>
      <div class="chat-input-wrap note-input-wrap">
        <textarea id="note-input" class="chat-textarea" rows="4"
          placeholder="What came up for you, if anything? (optional)"
          aria-label="Your reflection"></textarea>
      </div>
      <button class="practice-pill" id="save-btn">add note</button>
      <a href="/" class="btn-quiet" id="skip-btn">skip</a>
    </div>
  </div>

</div>

{% include "ambient-player.njk" %}
