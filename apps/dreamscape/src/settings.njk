---
layout: base.njk
title: Settings — Daily Practice
permalink: /settings/
pageScript: /assets/js/pages/settings.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">
  <div class="auth-page">

    <div class="circle-header">
      <div id="header-chime-wrap">
        {% include "wind-chime.njk" %}
      </div>
      <div class="feed-message feed-visible">
        <span class="feed-name" id="header-title">Settings</span>
        <span class="feed-time" id="header-email"></span>
      </div>
    </div>

    <div class="auth-steps">

      <div class="auth-step" id="step-loading">
        <p class="feed-time auth-step-label">…</p>
      </div>

      <div class="auth-step" id="step-settings" hidden>
        <div class="practice-field">
          <input type="text" id="settings-name" class="practice-name-input" placeholder="your name" autocomplete="given-name" maxlength="40">
        </div>
        <div class="settings-actions">
          <button class="btn-quiet" id="change-chime-btn">change chime</button>
          <button class="settings-sound-btn" id="sound-toggle-btn" aria-label="Toggle sound">
            <span class="settings-sound-label">sound</span>
            <svg id="settings-icon-on" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14"/>
            </svg>
            <svg id="settings-icon-off" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="display:none">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <line x1="23" y1="9" x2="17" y2="15"/>
              <line x1="17" y1="9" x2="23" y2="15"/>
            </svg>
          </button>
        </div>
        <p class="auth-error" id="name-error" hidden></p>
        <button class="pill" id="save-btn" hidden>save settings</button>
        <p class="settings-saved-indicator" id="settings-saved" hidden>saved</p>
      </div>

    </div>

  </div>
</div>
