---
layout: base.njk
title: Join — Daily Practice
permalink: /join/
pageScript: /assets/js/pages/join.js
noContainer: true
noFooter: true
bodyClass: scene-page
---

<div class="blossom-scene">
  <div class="auth-page">

    <div class="circle-header">
      <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.2" class="circle-icon" aria-hidden="true">
        <circle cx="24" cy="24" r="20"/>
        <circle cx="24" cy="24" r="7" class="circle-icon-center"/>
      </svg>
      <div class="feed-message feed-visible">
        <span class="feed-name">Daily Practice</span>
      </div>
    </div>

    <div class="auth-steps">

      <div class="auth-step" id="step-loading">
        <p class="feed-time auth-step-label">…</p>
      </div>

      <div class="auth-step" id="step-error" hidden>
        <p class="feed-time auth-step-label">this link doesn't work</p>
        <p class="auth-subtext">it may have been mistyped or removed</p>
      </div>

      <div class="auth-step" id="step-name" hidden>
        <div class="practice-field">
          <input type="text" id="join-name" class="practice-name-input" placeholder="your name" autocomplete="given-name" maxlength="40">
          <p class="feed-time auth-step-label" id="name-label">what's your name?</p>
        </div>
        <button class="pill" id="name-btn">continue</button>
      </div>

      <div class="auth-step" id="step-chime" hidden>
        <div class="practice-field">
          <div class="chime-preview" id="chime-preview" role="button" tabindex="0" aria-label="Play your chime">
            <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4" class="chime-icon" aria-hidden="true">
              <line x1="24" y1="8" x2="24" y2="36"/>
              <ellipse cx="24" cy="40" rx="5" ry="3"/>
              <line x1="14" y1="12" x2="14" y2="36"/>
              <ellipse cx="14" cy="40" rx="4" ry="2.5"/>
              <line x1="34" y1="16" x2="34" y2="36"/>
              <ellipse cx="34" cy="40" rx="4" ry="2.5"/>
              <path d="M10 10 C16 8 32 8 38 10"/>
            </svg>
          </div>
          <p class="feed-time auth-step-label">this is your chime</p>
          <p class="auth-subtext">your circle hears it when you practice</p>
        </div>
        <div class="auth-chime-actions">
          <button class="btn-quiet" id="chime-retry-btn">try another</button>
          <button class="pill" id="chime-btn">looks good</button>
        </div>
      </div>

      <div class="auth-step" id="step-email" hidden>
        <div class="practice-field">
          <input type="email" id="join-email" class="practice-name-input" placeholder="your@email.com" autocomplete="email" inputmode="email">
          <p class="feed-time auth-step-label">what's your email?</p>
          <p class="auth-subtext">we'll send you a link to join</p>
        </div>
        <p class="auth-error" id="join-error" hidden></p>
        <button class="pill" id="email-btn">send me a link</button>
      </div>

      <div class="auth-step" id="step-sent" hidden>
        <p class="feed-time auth-step-label">check your email</p>
        <p class="auth-subtext">we sent a link to <span id="join-sent-email"></span></p>
      </div>

      <div class="auth-step" id="step-connecting" hidden>
        <p class="feed-time auth-step-label">connecting…</p>
      </div>

    </div>

  </div>
</div>
