<div class="invite-screen" id="invite-screen">
  <div class="invite-loading" id="invite-loading">
    <p>Checking your invitation…</p>
  </div>
  <div class="invite-form" id="invite-form" hidden>
    <p class="invite-message" id="invite-message"></p>
    <input type="text" id="invite-name" class="invite-name-input" placeholder="Your name" maxlength="40" autocomplete="off">
    <button class="btn-primary" id="join-btn">Join the circle</button>
  </div>
  <div class="invite-error" id="invite-error" hidden>
    <p id="invite-error-message">This invitation is no longer valid.</p>
  </div>
</div>
