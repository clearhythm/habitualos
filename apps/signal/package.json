{
  "name": "signal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:widget": "node scripts/build-widget.js",
    "build:widget:watch": "node scripts/build-widget.js --watch",
    "start": "concurrently \"node scripts/build-widget.js --watch\" \"netlify dev\"",
    "eleventy:build": "eleventy",
    "eleventy:serve": "eleventy --serve --port=8080",
    "build": "npm run build:widget && eleventy",
    "ship": "bash scripts/ship.sh"
  },
  "dependencies": {
    "@11ty/eleventy": "^2.0.1",
    "@anthropic-ai/sdk": "^0.71.2",
    "@habitualos/auth-server": "workspace:*",
    "@habitualos/chat-storage": "workspace:*",
    "@habitualos/db-core": "workspace:*",
    "marked": "^15.0.12",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "esbuild-sass-plugin": "^3.7.0",
    "sass": "^1.69.5"
  }
}
