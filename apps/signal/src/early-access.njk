---
layout: base.njk
title: "Signal — Early Access Community"
description: "Signal is being built in the open. Early access is for professionals who use AI tools near-daily and have real work history worth surfacing. Raise your hand if that's you."
css: /styles/early-access.css
---
<div class="ea-page">
  <div class="ea-content-wrap">

    <h1 class="ea-headline">Get Early Access</h1>
    <p class="ea-subhead">We're building Signal in the open. Sign the guestbook and be one of the first Signal members when we're ready to support you. You're also close enough to shape what it becomes.</p>

    <div class="ea-tabs">
      <button class="ea-tab is-active" data-tab="sign">Sign the Guestbook</button>
      <button class="ea-tab" data-tab="signals">Recent Signals <span id="ea-count" class="ea-tab-count"></span></button>
    </div>

    <div id="ea-tab-sign">
      <div class="ea-top-grid">
        <div>
          <h2 id="ea-form-title" style="font-size: 1.75rem; font-weight: 700; margin: 0 0 1rem;">Sign the Guestbook</h2>
          <div id="ea-form-wrap">
            <div id="ea-step-1" class="ea-step">
              <div class="ea-form">
                <textarea
                  class="ea-textarea"
                  id="ea-message"
                  placeholder="Why are you interested? (or just say hi — anything goes)"
                ></textarea>
                <div class="ea-submit-row">
                  <button type="button" class="btn btn-primary" id="ea-next">Next →</button>
                  <span class="ea-hint">Nothing here is required.</span>
                </div>
              </div>
            </div>
            <div id="ea-step-2" class="ea-step" style="display:none">
              <form class="ea-form" id="ea-form" autocomplete="off">
                <div class="ea-form-row">
                  <input class="ea-input" id="ea-name" type="text" placeholder="Name or handle (optional)">
                  <input class="ea-input" id="ea-link" type="text" placeholder="LinkedIn or website (optional)">
                </div>
                <input class="ea-input" id="ea-email" type="email" placeholder="Email — only if you want to hear back (optional)">
                <div class="ea-submit-row">
                  <button type="submit" class="btn btn-primary" id="ea-submit">Save Entry →</button>
                  <button type="button" class="ea-edit-cancel" id="ea-back">← back</button>
                </div>
              </form>
            </div>
            <p class="ea-error" id="ea-error"></p>
          </div>
          <div class="ea-success" id="ea-success">
            <p class="ea-success-body">You're on the list. We'll reach out when your Signal profile is ready.</p>
            <div class="ea-success-actions">
              <button class="btn btn-outline" id="ea-success-edit-btn">Edit your entry</button>
              <button class="ea-delete-link" id="ea-success-delete-btn">Delete entry</button>
            </div>
          </div>
        </div>

        <blockquote class="ea-quote">
          <p>&#8220;Signal reads your actual work history — the more you build with AI tools, the stronger it gets. I built this because I needed it. If Claude Code, Cursor, or Codex is your daily driver, I want to get this in your hands.&#8221;</p>
          <cite>&#8212; <a href="https://erikburns.com" target="_blank" rel="noopener">Erik Burns</a>, creator of Signal</cite>
        </blockquote>
      </div>

    </div>

    <div id="ea-tab-signals" style="display:none">
      <div class="ea-list" id="ea-list">
        <p class="ea-loading">Loading…</p>
      </div>
    </div>

  </div>
  <img src="/assets/images/signal_monkey_bg.png" alt="" class="ea-bg-img" aria-hidden="true">
</div>

{% from "modal.njk" import confirm %}
{{ confirm("Delete your entry?", confirmLabel="Delete") }}

<script>
(function() {
  var MY_SUB_KEY = 'ea-submission';

  function getMySub() {
    try { return JSON.parse(localStorage.getItem(MY_SUB_KEY)) || null; } catch(e) { return null; }
  }
  function setMySub(data) {
    localStorage.setItem(MY_SUB_KEY, JSON.stringify(data));
  }
  function clearMySub() {
    localStorage.removeItem(MY_SUB_KEY);
  }

  function timeAgo(ts) {
    if (!ts) return '';
    var d = ts._seconds ? new Date(ts._seconds * 1000) : new Date(ts);
    var diff = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function escAttr(s) { return (s || '').replace(/"/g, '&quot;'); }
  function escHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function renderItem(item) {
    var displayName = item.name || '✋';
    var logoImg = '<img src="/assets/favicon-32x32.png" alt="" style="width:18px;height:18px;flex-shrink:0;display:block">';
    var href = item.link || null;
    var nameHtml = href
      ? '<a href="' + escAttr(href) + '" target="_blank" rel="noopener" class="ea-item-link" style="display:inline-flex;align-items:center;gap:0.5rem">' + logoImg + '<span>' + escHtml(displayName) + ' →</span></a>'
      : '<span class="ea-item-name" style="display:inline-flex;align-items:center;gap:0.5rem">' + logoImg + '<span>' + escHtml(displayName) + '</span></span>';
    var messageHtml = item.message ? '<p class="ea-item-message">' + escHtml(item.message) + '</p>' : '';
    var replyHtml = item.reply
      ? '<p class="ea-item-reply">' + escHtml(item.reply) + '</p><p class="ea-item-reply-attr">— Signal</p>'
      : '';
    return '<div class="ea-item" id="ea-item-' + item._id + '">' +
      '<div class="ea-item-meta">' + nameHtml + '<span class="ea-item-time">' + timeAgo(item.createdAt) + '</span></div>' +
      messageHtml + replyHtml +
      '</div>';
  }

  window.startEdit = function(id) {
    var mySub = getMySub();
    if (!mySub || mySub.id !== id) return;
    var itemEl = document.getElementById('ea-item-' + id);
    if (!itemEl) return;
    itemEl.innerHTML =
      '<form class="ea-edit-form" onsubmit="saveEdit(event, ' + JSON.stringify(id) + ')">' +
        '<textarea class="ea-textarea" id="ea-edit-message" style="min-height:80px">' + escHtml(mySub.message) + '</textarea>' +
        '<div class="ea-edit-row">' +
          '<input class="ea-input" id="ea-edit-name" type="text" placeholder="Name or handle" value="' + escAttr(mySub.name) + '">' +
          '<input class="ea-input" id="ea-edit-link" type="text" placeholder="LinkedIn or website" value="' + escAttr(mySub.link) + '">' +
        '</div>' +
        '<div class="ea-edit-actions">' +
          '<button type="submit" class="btn btn-primary" style="font-size:0.875rem;padding:0.5rem 1rem">Save</button>' +
          '<button type="button" class="ea-edit-cancel" onclick="cancelEdit()">cancel</button>' +
        '</div>' +
      '</form>';
  };

  window.cancelEdit = function() { loadList(); };

  window.saveEdit = function(e, id) {
    e.preventDefault();
    var name = document.getElementById('ea-edit-name').value.trim();
    var message = document.getElementById('ea-edit-message').value.trim();
    var link = document.getElementById('ea-edit-link').value.trim();
    if (link && !/^https?:\/\//i.test(link)) link = 'https://' + link;
    var saveBtn = e.target.querySelector('[type=submit]');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';
    fetch('/api/early-access-edit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: id, name: name, message: message, link: link })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          setMySub(Object.assign({}, getMySub(), { name: name, message: message, link: link }));
          loadList();
        } else { throw new Error(data.error || 'Something went wrong.'); }
      })
      .catch(function(err) {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
        alert(err.message);
      });
  };

  function loadList() {
    fetch('/api/early-access-list', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var listEl = document.getElementById('ea-list');
        var countEl = document.getElementById('ea-count');
        if (!data.success || !data.items.length) {
          if (listEl) listEl.innerHTML = '<p class="ea-empty">No one yet. Be the first.</p>';
          return;
        }
        if (countEl) countEl.textContent = '· ' + data.items.length;
        if (listEl) listEl.innerHTML = data.items.map(renderItem).join('');
      })
      .catch(function() {
        var listEl = document.getElementById('ea-list');
        if (listEl) listEl.innerHTML = '<p class="ea-empty">Couldn\'t load right now.</p>';
      });
  }

  var form = document.getElementById('ea-form');
  var submitBtn = document.getElementById('ea-submit');
  var nextBtn = document.getElementById('ea-next');
  var backBtn = document.getElementById('ea-back');
  var errorEl = document.getElementById('ea-error');
  var formWrap = document.getElementById('ea-form-wrap');
  var successEl = document.getElementById('ea-success');
  var step1 = document.getElementById('ea-step-1');
  var step2 = document.getElementById('ea-step-2');
  var formTitle = document.getElementById('ea-form-title');
  var isEditing = false;

  function showStep(n) {
    step1.style.opacity = '0';
    setTimeout(function() {
      step1.style.display = n === 1 ? '' : 'none';
      step2.style.display = n === 2 ? '' : 'none';
      errorEl.style.display = 'none';
      if (formTitle) formTitle.textContent = 'Sign the Guestbook';
      setTimeout(function() { (n === 1 ? step1 : step2).style.opacity = '1'; }, 20);
    }, 150);
  }

  step1.style.transition = 'opacity 0.15s';
  step2.style.transition = 'opacity 0.15s';

  var tabSign = document.getElementById('ea-tab-sign');
  var tabSignals = document.getElementById('ea-tab-signals');
  document.querySelectorAll('.ea-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.ea-tab').forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      var t = btn.dataset.tab;
      tabSign.style.display = t === 'sign' ? '' : 'none';
      tabSignals.style.display = t === 'signals' ? '' : 'none';
    });
  });

  function setSubmittedState() {
    formWrap.style.display = 'none';
    successEl.style.display = 'block';
    if (formTitle) formTitle.textContent = 'You\'re In ✋';
  }

  if (getMySub()) setSubmittedState();

  document.getElementById('ea-message').addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); showStep(2); }
  });

  nextBtn.addEventListener('click', function() { showStep(2); });
  backBtn.addEventListener('click', function() {
    if (isEditing) {
      formWrap.style.display = 'none';
      successEl.style.display = 'block';
      if (formTitle) formTitle.textContent = 'You\'re In ✋';
      isEditing = false;
      backBtn.textContent = '← back';
    } else {
      showStep(1);
    }
  });

  var successEditBtn = document.getElementById('ea-success-edit-btn');
  if (successEditBtn) {
    successEditBtn.addEventListener('click', function() {
      var mySub = getMySub();
      if (!mySub) return;
      successEl.style.display = 'none';
      formWrap.style.display = '';
      isEditing = true;
      document.getElementById('ea-message').value = mySub.message || '';
      document.getElementById('ea-name').value = mySub.name || '';
      document.getElementById('ea-link').value = mySub.link || '';
      document.getElementById('ea-email').value = mySub.email || '';
      step1.style.display = 'none';
      step2.style.display = '';
      step2.style.opacity = '1';
      if (formTitle) formTitle.textContent = 'Sign the Guestbook';
      errorEl.style.display = 'none';
      if (backBtn) backBtn.textContent = 'Cancel';
    });
  }

  var successDeleteBtn = document.getElementById('ea-success-delete-btn');
  if (successDeleteBtn) {
    successDeleteBtn.addEventListener('click', async function() {
      var mySub = getMySub();
      if (!mySub || !mySub.id) return;
      if (!await window.modal('Delete your entry?', { confirmLabel: 'Delete' })) return;
      successDeleteBtn.disabled = true;
      successDeleteBtn.textContent = 'Deleting…';
      fetch('/api/early-access-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: mySub.id })
      })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            clearMySub();
            successEl.style.display = 'none';
            formWrap.style.display = '';
            step1.style.display = '';
            step1.style.opacity = '1';
            step2.style.display = 'none';
            if (formTitle) formTitle.textContent = 'Sign the Guestbook';
            document.getElementById('ea-message').value = '';
            loadList();
          } else { throw new Error(data.error || 'Something went wrong.'); }
        })
        .catch(function(err) {
          successDeleteBtn.disabled = false;
          successDeleteBtn.textContent = 'Delete entry';
          alert(err.message);
        });
    });
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var name = document.getElementById('ea-name').value.trim();
    var message = document.getElementById('ea-message').value.trim();
    var email = document.getElementById('ea-email').value.trim();
    var link = document.getElementById('ea-link').value.trim();
    if (link && !/^https?:\/\//i.test(link)) link = 'https://' + link;

    var existing = getMySub();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving…';
    errorEl.style.display = 'none';

    var url, body;
    if (existing && existing.id) {
      url = '/api/early-access-edit';
      body = JSON.stringify({ id: existing.id, name: name, message: message, link: link });
    } else {
      url = '/api/early-access-submit';
      body = JSON.stringify({ name: name, message: message, email: email, link: link });
    }

    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: body
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          var id = existing ? existing.id : data.id;
          setMySub({ id: id, name: name, message: message, email: email, link: link });
          isEditing = false;
          backBtn.textContent = '← back';
          setSubmittedState();
          loadList();
        } else { throw new Error(data.error || 'Something went wrong.'); }
      })
      .catch(function(err) {
        errorEl.textContent = err.message;
        errorEl.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save Entry →';
      });
  });

  loadList();
})();
</script>
