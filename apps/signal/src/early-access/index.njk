---
layout: base.njk
title: "Signal — Early Access"
description: "Signal is an AI-native professional profile — your work history, in your voice. We're building this in the open. Raise your hand if you're watching."
---

<style>
  .ea-page {
    padding: 0 1.5rem;
    background: linear-gradient(to bottom, #130e28, #0a0d1a);
    min-height: calc(100dvh - 72px);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .ea-content-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 4rem 0 6rem;
    position: relative;
    z-index: 1;
    max-width: 640px;
    margin: 0 auto;
    width: 100%;
  }
  .ea-headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  .ea-subhead {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 520px;
  }
  .ea-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .ea-input, .ea-textarea {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #f9fafb;
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    width: 100%;
    outline: none;
    font-family: inherit;
    transition: border-color 0.15s;
  }
  .ea-input::placeholder, .ea-textarea::placeholder {
    color: rgba(255,255,255,0.3);
  }
  .ea-input:focus, .ea-textarea:focus {
    border-color: rgba(124,58,237,0.6);
  }
  .ea-textarea {
    resize: vertical;
    min-height: 100px;
    line-height: 1.6;
  }
  .ea-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  @media (max-width: 480px) {
    .ea-form-row { grid-template-columns: 1fr; }
  }
  .ea-submit-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ea-hint {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
  }
  .ea-error {
    font-size: 0.875rem;
    color: #fca5a5;
    display: none;
  }
  .ea-success {
    font-size: 1rem;
    color: #86efac;
    padding: 1rem 0;
    display: none;
  }

  .ea-divider {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin: 2.5rem 0;
  }

  .ea-list-label {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0 0 1.25rem;
  }
  .ea-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .ea-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .ea-item-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .ea-item-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e2e8f0;
  }
  .ea-item-link {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
  }
  .ea-item-link:hover { border-bottom-color: #7c3aed; color: rgba(255,255,255,0.7); }
  .ea-item-time {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.25);
    margin-left: auto;
  }
  .ea-item-message {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
  }
  .ea-item-reply {
    font-size: 0.85rem;
    color: #c4b5fd;
    line-height: 1.6;
    padding-left: 1rem;
    border-left: 2px solid rgba(124,58,237,0.4);
    margin-top: 0.25rem;
  }
  .ea-item-reply-attr {
    font-size: 0.75rem;
    color: rgba(124,58,237,0.6);
    margin-top: 0.2rem;
    padding-left: 1rem;
  }
  .ea-empty {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.25);
    font-style: italic;
  }
  .ea-loading {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.25);
  }
  .ea-item-edit-btn {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-decoration-color: rgba(255,255,255,0.15);
    margin-left: auto;
  }
  .ea-item-edit-btn:hover { color: rgba(255,255,255,0.6); }
  .ea-edit-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .ea-edit-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  @media (max-width: 480px) {
    .ea-edit-row { grid-template-columns: 1fr; }
  }
  .ea-edit-actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .ea-edit-cancel {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .ea-edit-cancel:hover { color: rgba(255,255,255,0.6); }

  .ea-bg-img {
    display: block;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(-1);
    width: 100%;
    max-width: 900px;
    opacity: 0.15;
    pointer-events: none;
    filter: invert(1);
    mix-blend-mode: screen;
  }
</style>

<div class="ea-page">
  <div class="ea-content-wrap">

    <h1 class="ea-headline">What do you see?</h1>
    <p class="ea-subhead">Signal is an AI-native professional profile — your work history, in your voice, available to anyone who wants to understand what you can do. We're building this in the open. Raise your hand if you're watching.</p>

    <div id="ea-form-wrap">
      <form class="ea-form" id="ea-form" autocomplete="off">
        <textarea
          class="ea-textarea"
          id="ea-message"
          placeholder="Why are you interested? (or just say hi — anything goes)"
        ></textarea>
        <div class="ea-form-row">
          <input class="ea-input" id="ea-name" type="text" placeholder="Name or handle (optional)">
          <input class="ea-input" id="ea-link" type="url" placeholder="LinkedIn or website (optional)">
        </div>
        <input class="ea-input" id="ea-email" type="email" placeholder="Email — only if you want to hear back (optional)">
        <div class="ea-submit-row">
          <button type="submit" class="btn btn-primary" id="ea-submit">Raise my hand →</button>
          <span class="ea-hint">Nothing here is required.</span>
        </div>
      </form>
      <p class="ea-error" id="ea-error"></p>
    </div>
    <div class="ea-success" id="ea-success">✋ You're in. Thanks for being here.</div>

    <hr class="ea-divider">

    <p class="ea-list-label">Raised hands</p>
    <div class="ea-list" id="ea-list">
      <p class="ea-loading">Loading…</p>
    </div>

  </div>
  <img src="/assets/images/signal_monkey_bg.png" alt="" class="ea-bg-img" aria-hidden="true">
</div>

<script>
(function() {
  var MY_SUB_KEY = 'ea-submission';

  function getMySub() {
    try { return JSON.parse(localStorage.getItem(MY_SUB_KEY)) || null; } catch(e) { return null; }
  }
  function setMySub(data) {
    localStorage.setItem(MY_SUB_KEY, JSON.stringify(data));
  }

  function timeAgo(ts) {
    if (!ts) return '';
    var d = ts._seconds ? new Date(ts._seconds * 1000) : new Date(ts);
    var diff = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diff < 60) return 'just now';
    if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
    if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
    return Math.floor(diff / 86400) + 'd ago';
  }

  function escAttr(s) { return (s || '').replace(/"/g, '&quot;'); }
  function escHtml(s) { return (s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function renderItem(item, isMine) {
    var name = item.name || '✋';
    var nameHtml = item.link
      ? '<a href="' + item.link + '" target="_blank" rel="noopener" class="ea-item-link">' + escHtml(name) + ' →</a>'
      : '<span class="ea-item-name">' + escHtml(name) + '</span>';
    var messageHtml = item.message
      ? '<p class="ea-item-message">' + escHtml(item.message) + '</p>'
      : '';
    var replyHtml = item.reply
      ? '<p class="ea-item-reply">' + escHtml(item.reply) + '</p><p class="ea-item-reply-attr">— Signal</p>'
      : '';
    var editBtn = isMine
      ? '<button class="ea-item-edit-btn" onclick="startEdit(' + JSON.stringify(item._id) + ')">edit</button>'
      : '';
    return '<div class="ea-item" id="ea-item-' + item._id + '">' +
      '<div class="ea-item-meta">' + nameHtml + editBtn + '<span class="ea-item-time">' + timeAgo(item.createdAt) + '</span></div>' +
      messageHtml + replyHtml +
      '</div>';
  }

  window.startEdit = function(id) {
    var mySub = getMySub();
    if (!mySub || mySub.id !== id) return;
    var itemEl = document.getElementById('ea-item-' + id);
    if (!itemEl) return;
    itemEl.innerHTML =
      '<form class="ea-edit-form" onsubmit="saveEdit(event, ' + JSON.stringify(id) + ')">' +
        '<textarea class="ea-textarea" id="ea-edit-message" style="min-height:80px">' + escHtml(mySub.message) + '</textarea>' +
        '<div class="ea-edit-row">' +
          '<input class="ea-input" id="ea-edit-name" type="text" placeholder="Name or handle" value="' + escAttr(mySub.name) + '">' +
          '<input class="ea-input" id="ea-edit-link" type="url" placeholder="LinkedIn or website" value="' + escAttr(mySub.link) + '">' +
        '</div>' +
        '<div class="ea-edit-actions">' +
          '<button type="submit" class="btn btn-primary" style="font-size:0.875rem;padding:0.5rem 1rem">Save</button>' +
          '<button type="button" class="ea-edit-cancel" onclick="cancelEdit()">cancel</button>' +
        '</div>' +
      '</form>';
  };

  window.cancelEdit = function() { loadList(); };

  window.saveEdit = function(e, id) {
    e.preventDefault();
    var name = document.getElementById('ea-edit-name').value.trim();
    var message = document.getElementById('ea-edit-message').value.trim();
    var link = document.getElementById('ea-edit-link').value.trim();
    var saveBtn = e.target.querySelector('[type=submit]');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving…';

    fetch('/api/early-access-edit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: id, name: name, message: message, link: link })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          setMySub({ id: id, name: name, message: message, link: link });
          loadList();
        } else {
          throw new Error(data.error || 'Something went wrong.');
        }
      })
      .catch(function(err) {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save';
        alert(err.message);
      });
  };

  function loadList() {
    fetch('/api/early-access-list', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var listEl = document.getElementById('ea-list');
        if (!data.success || !data.items.length) {
          listEl.innerHTML = '<p class="ea-empty">No hands raised yet. Be the first.</p>';
          return;
        }
        var mySub = getMySub();
        listEl.innerHTML = data.items.map(function(item) {
          return renderItem(item, mySub && mySub.id === item._id);
        }).join('');
      })
      .catch(function() {
        document.getElementById('ea-list').innerHTML = '<p class="ea-empty">Couldn\'t load responses right now.</p>';
      });
  }

  var form = document.getElementById('ea-form');
  var submitBtn = document.getElementById('ea-submit');
  var errorEl = document.getElementById('ea-error');
  var formWrap = document.getElementById('ea-form-wrap');
  var successEl = document.getElementById('ea-success');

  // Restore submitted state on load
  if (getMySub()) {
    formWrap.style.display = 'none';
    successEl.style.display = '';
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var name = document.getElementById('ea-name').value.trim();
    var message = document.getElementById('ea-message').value.trim();
    var email = document.getElementById('ea-email').value.trim();
    var link = document.getElementById('ea-link').value.trim();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorEl.style.display = 'none';

    fetch('/api/early-access-submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name, message: message, email: email, link: link })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.success) {
          setMySub({ id: data.id, name: name, message: message, link: link });
          formWrap.style.display = 'none';
          successEl.style.display = '';
          loadList();
        } else {
          throw new Error(data.error || 'Something went wrong.');
        }
      })
      .catch(function(err) {
        errorEl.textContent = err.message;
        errorEl.style.display = '';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Raise my hand →';
      });
  });

  loadList();
})();
</script>
