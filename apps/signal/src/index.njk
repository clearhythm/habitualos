<script>
  (function () {
    var track  = document.querySelector('.signal-carousel-track');
    var inner  = document.getElementById('carousel-inner');
    var slides = Array.from(document.querySelectorAll('.signal-carousel-slide'));
    var dots   = Array.from(document.querySelectorAll('.signal-dot'));
    if (!track || !inner || !slides.length) return;

    var current = 0;
    var timer = null;
    var INTERVAL = 9000;

    function setWidths() {
      var w = track.offsetWidth;
      slides.forEach(function (s) { s.style.width = w + 'px'; });
      inner.style.transform = 'translateX(-' + (current * w) + 'px)';
    }

    function animateBars(slide) {
      var fills = slide.querySelectorAll('.signal-sample-fill[data-width]');
      fills.forEach(function (el) { el.style.width = '0'; });
      setTimeout(function () {
        fills.forEach(function (el) { el.style.width = el.dataset.width + '%'; });
      }, 80);
    }

    function goTo(index) {
      if (index === current) return;
      slides[current].classList.remove('is-active');
      dots[current].classList.remove('is-active');
      dots[current].setAttribute('aria-selected', 'false');
      current = index;
      inner.style.transform = 'translateX(-' + (index * track.offsetWidth) + 'px)';
      slides[current].classList.add('is-active');
      dots[current].classList.add('is-active');
      dots[current].setAttribute('aria-selected', 'true');
      animateBars(slides[current]);
    }

    function startTimer() {
      timer = setInterval(function () { goTo((current + 1) % slides.length); }, INTERVAL);
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        clearInterval(timer);
        goTo(parseInt(dot.dataset.index, 10));
        startTimer();
      });
    });

    window.addEventListener('resize', setWidths);
    setWidths();

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          animateBars(slides[0]);
          startTimer();
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });
    observer.observe(slides[0]);
  })();
</script>
