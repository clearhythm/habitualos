---
layout: base.njk
title: "Signal — Dashboard"
pageTitle: Dashboard
description: "Your Signal activity and opportunity evaluations."
pageScript: /assets/js/dashboard.js
showDemoModal: true
---

<div class="dash-wrap">

  <!-- Auth guard: shown while checking session -->
  <div id="dash-loading" class="dash-loading">
    <p class="text-muted">Loading…</p>
  </div>

  <!-- Main dashboard (shown after auth check) -->
  <div id="dash-main" hidden>

    <div class="dash-header">
      <div>
        <p class="signal-hero-eyebrow">Dashboard</p>
        <h1 class="dash-title" id="dash-display-name">Your Signal</h1>
        <p class="dash-signal-id text-muted">signal.habitualos.com/widget/?id=<span id="dash-signal-id">—</span></p>
      </div>
      <div class="dash-header-actions">
        <a href="/profile/" class="btn btn-ghost">Edit profile →</a>
        <a id="dash-preview-link" href="#" class="btn btn-ghost" target="_blank" rel="noopener">Preview widget →</a>
      </div>
    </div>

    <div class="dash-sections">

      <!-- Opportunity Fit -->
      <section class="dash-section">
        <h2 class="dash-section-title">Evaluate an opportunity</h2>
        <p class="dash-section-desc">Paste a job description, project brief, or role details to see how well it fits your Signal profile.</p>

        <form id="eval-form">
          <div class="dash-gap-field" style="margin-bottom:0.75rem;">
            <label class="signal-label">Title (optional)</label>
            <input class="signal-input-field" id="eval-title" type="text" placeholder="e.g. Senior AI Product Lead — Seed Stage" maxlength="200" />
          </div>
          <textarea class="dash-textarea" id="eval-content" rows="8"
            placeholder="Paste job description, project brief, or opportunity details here…"></textarea>
          <div class="dash-form-actions">
            <button type="submit" class="btn btn-primary" id="eval-submit-btn">Evaluate fit →</button>
            <span class="dash-save-status" id="eval-status"></span>
          </div>
        </form>

        <!-- Result panel (shown after evaluation) -->
        <div id="eval-result" class="eval-result-panel" hidden></div>

        <!-- Generated content (resume / cover letter) -->
        <div id="eval-generated" hidden>
          <div id="eval-resume-panel" class="eval-generated-panel" hidden></div>
          <div id="eval-cover-panel" class="eval-generated-panel" hidden></div>
        </div>

        <!-- History -->
        <div id="eval-history-wrap" hidden>
          <h3 class="eval-history-title">Past evaluations</h3>
          <div id="eval-history-list" class="eval-history-list"></div>
        </div>
      </section>

      <!-- Leads -->
      <section class="dash-section">
        <h2 class="dash-section-title">Recent leads</h2>
        <p class="dash-section-desc">Visitors who completed a Signal conversation, sorted by fit score.</p>
        <div id="leads-list" class="dash-leads-list">
          <p class="dash-no-leads" id="leads-empty" hidden>No leads yet. Share your Signal widget to start collecting.</p>
        </div>
      </section>

    </div>
  </div>


</div>
