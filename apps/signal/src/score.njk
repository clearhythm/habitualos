---
layout: base.njk
title: "Signal — Score Your Fit"
description: "Paste your resume and a job description. Get scored. Then get coached through exactly what to change."
pageScript: /assets/js/score.js
---

<div class="score-page">

  <!-- States 1–3 + limit: form, scoring, result -->
  <div class="score-wrap" id="score-main">

    <!-- Past evals history strip -->
    <div id="score-history" class="score-history" hidden></div>

    <!-- State 1 & 2: Input form -->
    <div id="score-form">
      <h1 class="score-heading">Score your fit. Fix your resume.</h1>
      <p class="score-subhead">Paste your resume and a job description. Get scored. Then get coached through exactly what to change.</p>

      <div class="score-inputs">
        <div>
          <label class="score-field-label" for="score-resume">Your resume</label>
          <textarea class="score-textarea score-textarea--resume" id="score-resume"
            placeholder="Paste your resume text here..."></textarea>
        </div>

        <div>
          <label class="score-field-label" for="score-jd">Job description</label>
          <textarea class="score-textarea" id="score-jd"
            placeholder="Paste the full job description here..."></textarea>
        </div>

        <div class="score-actions">
          <button class="score-submit-btn" id="score-submit-btn" type="button">Score my fit</button>
          <p class="score-progress" id="score-progress">Analyzing…</p>
          <p class="score-error" id="score-error"></p>
        </div>
      </div>
    </div>

    <!-- Limit state (shown when 3 free evals used) -->
    <div id="score-limit" class="score-limit" hidden>
      <h2 class="score-limit-heading">You've used your 3 free scores</h2>
      <p class="score-limit-body">Create a free Signal account to score unlimited roles and build your full profile — including a shareable fit widget for recruiters.</p>
      <a class="score-upsell-cta" id="score-limit-cta" href="/register/">Create your Signal →</a>
    </div>

    <!-- State 3: Score result -->
    <div id="score-result" class="score-result hidden">

      <div class="score-card" id="score-card"></div>

      <button class="score-coach-btn" id="score-coach-btn" type="button" hidden>Improve my score →</button>

      <button class="score-again-btn" id="score-again-btn" type="button" hidden>Score another role</button>

      <div class="score-upsell" id="score-upsell" hidden>
        <h3 class="score-upsell-heading">Build your full Signal profile</h3>
        <p class="score-upsell-body">Your Signal profile connects your actual work history — Claude Code sessions, GitHub commits, decisions — to a shareable fit widget recruiters can talk to.</p>
        <a class="score-upsell-cta" id="score-upsell-cta" href="/register/">Create your Signal →</a>
      </div>

    </div>

  </div>

  <!-- State 4: Coach chat (full-height) -->
  <div class="score-coach" id="score-coach" hidden>
    <div class="score-coach-header">
      <button class="score-coach-back" id="score-coach-back" type="button">← Back</button>
      <span class="score-coach-title">Resume Coach</span>
    </div>
    <div class="score-coach-messages" id="score-coach-messages"></div>
    <div class="score-coach-input-wrap">
      <textarea class="score-coach-textarea" id="score-coach-input" placeholder="Type your answer…" rows="2"></textarea>
      <button class="score-coach-send" id="score-coach-send" type="button">Send</button>
    </div>
  </div>

  <!-- State 5: Building (full-height) -->
  <div class="score-building" id="score-building" hidden>
    <div class="score-building-inner">
      <div class="score-building-spinner"></div>
      <p class="score-building-text">Rewriting your resume…</p>
      <p class="score-building-sub">This takes about 30 seconds.</p>
    </div>
  </div>

  <!-- State 6: Improved result -->
  <div class="score-wrap" id="score-improved-wrap" hidden>
    <div id="score-improved">
      <div class="score-delta-badge" id="score-delta-badge"></div>
      <div id="score-rewrite-cards"></div>
      <div id="score-no-improve-msg" class="score-no-improve-msg" hidden></div>
      <div class="score-upsell" style="margin-top:2rem">
        <h3 class="score-upsell-heading">Keep your improved resume</h3>
        <p class="score-upsell-body">Create a Signal account to save your coaching session, build your full profile, and share a live fit widget with recruiters.</p>
        <a class="score-upsell-cta" id="score-improved-cta" href="/register/">Create your Signal →</a>
      </div>
    </div>
  </div>

</div>
