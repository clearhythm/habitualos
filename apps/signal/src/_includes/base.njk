<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Signal" }}</title>
  <meta name="description" content="{{ description or 'Signal' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <link rel="stylesheet" href="/styles/main.css">
  <script>
    (function() {
      const userId = localStorage.getItem('userId') || (() => {
        const id = 'u-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
        localStorage.setItem('userId', id);
        return id;
      })();
      window.__userId = userId;
      if (localStorage.getItem('signal-owner-id')) {
        document.addEventListener('DOMContentLoaded', function() {
          var el = document.getElementById('nav-dashboard');
          if (el) el.removeAttribute('hidden');
          var el2 = document.getElementById('nav-profile');
          if (el2) el2.removeAttribute('hidden');
        });
      }
    })();
  </script>
</head>
<body>

  <nav class="navbar">
    <div class="sidemenu">
      {% include "nav.njk" %}
      <div class="sidemenu-main" id="sidemenu-main">
        <div class="sidemenu-left">
          <ul>
            <li><a href="/how-it-works/">How Signal Works</a></li>
            <li><a href="/demo/" id="sidemenu-demo-open">Score your Signal</a></li>
            <li><a href="/waitlist/">Create yours</a></li>
            <li hidden id="nav-dashboard"><a href="/dashboard/">Dashboard</a></li>
            <li hidden id="nav-profile"><a href="/profile/">Profile</a></li>
          </ul>
          <div class="sidemenu-footer-row">
            <img src="/assets/images/signal-logo.png" alt="" class="sidemenu-logo">
            <p class="sidemenu-copyright">Signal — Professional networking built on real work</p>
          </div>
        </div>
        <div class="sidemenu-right">
          <div class="sidemenu-overlay" id="sidemenu-overlay"></div>
        </div>
      </div>
    </div>
    <a class="navbar-brand" href="/">{{ pageTitle or "Signal" }}</a>
  </nav>

  <main class="main">
    {{ content | safe }}
  </main>

  {% if showDemoModal %}
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <div class="signal-modal-overlay" id="signal-modal" aria-modal="true" role="dialog" hidden>
    <div class="signal-modal-inner">
      <div class="signal-modal-header">
        <span class="signal-modal-title">Signal Fit</span>
        <button class="signal-modal-close" id="signal-modal-close" aria-label="Close">
          <span></span><span></span>
        </button>
      </div>
      <div class="signal-modal-body">
        <div class="signal-widget" id="signal-widget">

          <div class="signal-panel signal-panel--score">
            <div class="signal-score-header">
              <span class="signal-score-label" id="signal-score-label">Summary of Scores</span>
              <span class="signal-confidence-label">Confidence <span id="confidence-pct">—</span></span>
            </div>
            <div class="signal-overall-wrap" id="overall-wrap">
              <svg class="signal-ring" viewBox="0 0 120 120" aria-hidden="true">
                <circle class="signal-ring-track" cx="60" cy="60" r="52"/>
                <circle class="signal-ring-fill" id="overall-ring" cx="60" cy="60" r="52"/>
              </svg>
              <div class="signal-overall-score" id="overall-score">—</div>
            </div>
            <div class="signal-confidence-bar-wrap">
              <div class="signal-confidence-bar" id="confidence-bar"></div>
            </div>
            <div class="signal-dimensions">
              <div class="signal-dimension">
                <div class="signal-dimension-header">
                  <span class="signal-dimension-name">Skills</span>
                  <span class="signal-dimension-value" id="skills-value">—</span>
                </div>
                <div class="signal-bar-track"><div class="signal-bar-fill" id="skills-bar"></div></div>
              </div>
              <div class="signal-dimension">
                <div class="signal-dimension-header">
                  <span class="signal-dimension-name">Alignment</span>
                  <span class="signal-dimension-value" id="alignment-value">—</span>
                </div>
                <div class="signal-bar-track"><div class="signal-bar-fill" id="alignment-bar"></div></div>
              </div>
              <div class="signal-dimension">
                <div class="signal-dimension-header">
                  <span class="signal-dimension-name">Personality</span>
                  <span class="signal-dimension-value" id="personality-value">—</span>
                </div>
                <div class="signal-bar-track"><div class="signal-bar-fill" id="personality-bar"></div></div>
              </div>
            </div>
            <div class="signal-reason" id="signal-reason" aria-live="polite"></div>
            <div class="signal-score-footer">
              <span class="signal-score-footer-text">Score builds as the conversation develops</span>
            </div>
            <div class="signal-next-step" id="signal-next-step" hidden>
              <div class="signal-next-step-label" id="next-step-label"></div>
              <div class="signal-next-step-actions" id="next-step-actions"></div>
            </div>
          </div>

          <div class="signal-score-bar-mobile" id="score-bar-mobile" aria-hidden="true">
            <span class="signal-score-bar-num" id="score-bar-num">—</span>
            <span class="signal-score-bar-label" id="score-bar-label">Assessing readiness…</span>
          </div>

          <div class="signal-panel signal-panel--chat">
            <div class="signal-persona-wrap" id="persona-wrap">
              <p class="signal-persona-prompt" id="persona-prompt">Loading…</p>
              <div class="signal-persona-btns" id="persona-btns"></div>
            </div>
            <div class="signal-messages" id="signal-messages" aria-live="polite" aria-label="Conversation"></div>
            <form class="signal-form" id="signal-form" aria-label="Send a message">
              <textarea
                class="signal-input"
                id="signal-input"
                placeholder="Tell me about your AI work…"
                rows="3"
                aria-label="Your message"
                disabled
              ></textarea>
              <button type="submit" class="signal-send" id="signal-send" aria-label="Send" disabled>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M22 2L15 22L11 13L2 9L22 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </form>
            <div class="signal-chat-footer">
              <a href="/" class="signal-brand-logo" aria-label="Signal">
                <img src="/assets/images/signal-logo.png" alt="Signal" class="signal-logo-img" />
              </a>
              <span class="signal-brand-sub">Professional networking built on real work</span>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
  <script type="module" src="/assets/js/signal-modal.js"></script>
  {% endif %}

  <footer class="site-footer">
    <div class="container">
      <img src="/assets/images/signal-logo.png" alt="" class="footer-logo">
      <p>© 2026 Signal. Built by Erik Burns on HabitualOS.</p>
      <p><a href="/waitlist/">Join the waitlist</a> &middot; <a href="https://habitualos.com" target="_blank" rel="noopener">HabitualOS</a></p>
    </div>
  </footer>

  <script src="/assets/js/navigation.js"></script>
  {% if pageScript %}
  <script type="module" src="{{ pageScript }}"></script>
  {% endif %}
</body>
</html>
