<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Signal" }}</title>
  <meta name="description" content="{{ description or 'Signal' }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
  <link rel="stylesheet" href="/styles/main.css">
  <script>
    // userId must be available before any module scripts run
    window.__userId = localStorage.getItem('userId') || (function() {
      var id = 'u-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
      localStorage.setItem('userId', id);
      return id;
    })();
  </script>
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>

  <nav class="navbar">
    <div class="sidemenu">
      {% include "nav.njk" %}
      <div class="sidemenu-main" id="sidemenu-main">
        <div class="sidemenu-left">
          <ul>
            <li><a href="/how-it-works/">How Signal Works</a></li>
            <li><a href="/demo/" id="sidemenu-demo-open">Score your Signal</a></li>
            <li><a href="/waitlist/">Create yours</a></li>
            <li hidden id="nav-dashboard"><a href="/dashboard/">Dashboard</a></li>
            <li hidden id="nav-profile"><a href="/profile/">Profile</a></li>
          </ul>

          <div class="sidemenu-auth">
            <div id="nav-signed-out" class="sidemenu-auth-state" hidden>
              <a href="/signin/" class="sidemenu-auth-link">Sign in</a>
            </div>
            <div id="nav-signed-in" class="sidemenu-auth-state" hidden>
              <span class="sidemenu-auth-name" id="nav-auth-name"></span>
              <button class="sidemenu-auth-link" id="nav-signout-btn">Sign out</button>
            </div>
          </div>

          <div class="sidemenu-footer-row">
            <img src="/assets/favicon-32x32.png" alt="" class="sidemenu-logo">
            <p class="sidemenu-copyright">Signal — Professional networking built on real work</p>
          </div>
        </div>
        <div class="sidemenu-right">
          <div class="sidemenu-overlay" id="sidemenu-overlay"></div>
        </div>
      </div>
    </div>
    <a class="navbar-brand" href="/"><img src="/assets/favicon-32x32.png" alt="" class="navbar-brand-icon" aria-hidden="true">{{ pageTitle or "Signal" }}</a>
  </nav>

  <main class="main">
    {{ content | safe }}
  </main>

  {% if showDemoModal %}
  {% from "modal.njk" import widget %}
  {{ widget() }}
  {% endif %}

  <footer class="site-footer">
    <div class="container">
      <img src="/assets/favicon-32x32.png" alt="" class="footer-logo">
      <p>© 2026 Erik Burns | Signal, built on HabitualOS</p>
      <p><a href="/waitlist/">Join the waitlist</a> &middot; <a href="https://habitualos.com" target="_blank" rel="noopener">HabitualOS</a></p>
    </div>
  </footer>

  <script src="/assets/js/navigation.js"></script>
  {% if pageScript %}
  <script type="module" src="{{ pageScript }}"></script>
  {% endif %}

  <script>
    // Auth nav state — runs after body so elements exist, no DOMContentLoaded needed
    (function() {
      var signedIn = !!localStorage.getItem('signal-owner-id');
      var signedOutEl = document.getElementById('nav-signed-out');
      var signedInEl  = document.getElementById('nav-signed-in');

      if (signedIn) {
        if (signedInEl)  signedInEl.removeAttribute('hidden');

        var nameEl = document.getElementById('nav-auth-name');
        if (nameEl) nameEl.textContent = localStorage.getItem('signal-owner-name') || '';

        var dash = document.getElementById('nav-dashboard');
        if (dash) dash.removeAttribute('hidden');
        var prof = document.getElementById('nav-profile');
        if (prof) prof.removeAttribute('hidden');

        var signOutBtn = document.getElementById('nav-signout-btn');
        if (signOutBtn) {
          signOutBtn.addEventListener('click', function() {
            localStorage.removeItem('signal-owner-id');
            localStorage.removeItem('signal-owner-name');
            window.location.href = '/';
          });
        }
      } else {
        if (signedOutEl) signedOutEl.removeAttribute('hidden');
      }
    })();
  </script>
</body>
</html>
