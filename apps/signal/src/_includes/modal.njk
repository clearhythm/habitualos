{% macro confirm(message="Are you sure?", confirmLabel="Delete", cancelLabel="Cancel", id="modal-confirm") %}
<div id="{{ id }}" class="modal-overlay modal-overlay--small" hidden aria-modal="true" role="dialog" aria-labelledby="{{ id }}-message">
  <div class="modal modal--small">
    <p class="modal-message" id="{{ id }}-message">{{ message }}</p>
    <div class="modal-actions">
      <button class="btn btn-ghost" data-modal-cancel>{{ cancelLabel }}</button>
      <button class="btn btn-danger" data-modal-ok>{{ confirmLabel }}</button>
    </div>
  </div>
</div>
<script type="module" src="/assets/js/modal.js"></script>
{% endmacro %}


{% macro widget() %}
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<div class="signal-modal-overlay" id="signal-modal" aria-modal="true" role="dialog" hidden>
  <div class="signal-modal-header">
    <span class="signal-modal-title">Signal Fit</span>
    <button class="signal-modal-close" id="signal-modal-close" aria-label="Close">
      <span></span><span></span>
    </button>
  </div>
  <div class="signal-modal-body">
    <div class="signal-widget" id="signal-widget">

        <div class="signal-panel signal-panel--score">
          <div class="signal-mobile-header" id="signal-mobile-header">
            <span class="signal-mobile-agent-name" id="mobile-agent-name">Erik's Agent</span>
            <span class="signal-mobile-score" id="mobile-score-pill"></span>
            <span class="signal-mobile-chevron">↓</span>
          </div>
          <div class="signal-panel-tabs">
            <button class="signal-tab is-active" data-tab="profile">Profile</button>
            <button class="signal-tab" data-tab="score" id="tab-score">Score <span class="signal-tab-badge" id="tab-score-badge"></span></button>
          </div>
          <div class="signal-phase-wrap">

            <!-- Profile tab -->
            <div class="signal-agent-left" id="signal-agent-left">
              <div class="signal-agent-left-name" id="signal-agent-left-name">Erik's Agent</div>
              <div class="signal-agent-avatar-wrap">
                <img class="signal-agent-avatar-left" src="/assets/images/signal-agent_clean.png" alt="" />
              </div>
              <p class="signal-agent-creds-intro" id="signal-agent-creds-intro"></p>
              <ul class="signal-agent-left-creds" id="signal-agent-left-creds"></ul>
              <p class="signal-agent-updated" id="signal-agent-updated"></p>
              <div class="signal-agent-contact" id="signal-agent-contact"></div>


            </div>

            <!-- Score tab -->
            <div class="signal-score-inner" id="signal-score-inner">
              <span class="signal-score-label" id="signal-score-label">Fit Score</span>
              <div class="signal-overall-wrap" id="overall-wrap">
                <svg class="signal-ring" viewBox="0 0 120 120" aria-hidden="true">
                  <circle class="signal-ring-track" cx="60" cy="60" r="52"/>
                  <circle class="signal-ring-fill" id="overall-ring" cx="60" cy="60" r="52"/>
                </svg>
                <div class="signal-overall-score" id="overall-score"></div>
              </div>
              <div class="signal-dimensions">
                <div class="signal-dimension">
                  <div class="signal-dimension-header">
                    <span class="signal-dimension-name">Skills</span>
                    <span class="signal-dimension-value" id="skills-value"></span>
                  </div>
                  <div class="signal-bar-track"><div class="signal-bar-fill" id="skills-bar"></div></div>
                </div>
                <div class="signal-dimension">
                  <div class="signal-dimension-header">
                    <span class="signal-dimension-name">Alignment</span>
                    <span class="signal-dimension-value" id="alignment-value"></span>
                  </div>
                  <div class="signal-bar-track"><div class="signal-bar-fill" id="alignment-bar"></div></div>
                </div>
                <div class="signal-dimension">
                  <div class="signal-dimension-header">
                    <span class="signal-dimension-name">Personality</span>
                    <span class="signal-dimension-value" id="personality-value"></span>
                  </div>
                  <div class="signal-bar-track"><div class="signal-bar-fill" id="personality-bar"></div></div>
                </div>
              </div>
              <div class="signal-confidence-section" hidden>
                <div class="signal-confidence-header">
                  <span class="signal-confidence-label">Confidence</span>
                  <span class="signal-confidence-label" id="confidence-pct"></span>
                </div>
                <span class="signal-score-footer-text">Updates with your input</span>
              </div>
              <div class="signal-reason" id="signal-reason" aria-live="polite"></div>
              <div class="signal-score-recommendation" id="signal-recommendation" hidden></div>
            </div>

          </div>
          <div class="signal-panel-footer">
            <a href="https://signal.habitualos.com" target="_blank" rel="noopener" class="signal-footer-cta">
              <img src="/assets/favicon-32x32.png" alt="" class="signal-favicon-icon" aria-hidden="true" /><strong class="signal-footer-brand">Signal.</strong> Get your own →
            </a>
          </div>
        </div>

        <div class="signal-score-bar-mobile" id="score-bar-mobile" aria-hidden="true">
          <span class="signal-score-bar-num" id="score-bar-num"></span>
          <span class="signal-score-bar-label" id="score-bar-label">Assessing readiness…</span>
        </div>

        <div class="signal-panel signal-panel--chat">
          <div class="signal-persona-wrap" id="persona-wrap">
            <p class="signal-persona-prompt" id="persona-prompt">Loading…</p>
            <div class="signal-persona-btns" id="persona-btns"></div>
          </div>
          <div class="signal-messages" id="signal-messages" aria-live="polite" aria-label="Conversation"></div>
          <form class="signal-form" id="signal-form" aria-label="Send a message">
            <textarea
              class="signal-input"
              id="signal-input"
              placeholder="Tell me about your AI work…"
              rows="3"
              aria-label="Your message"
              disabled
            ></textarea>
            <button type="submit" class="signal-send" id="signal-send" aria-label="Send" disabled>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M22 2L11 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M22 2L15 22L11 13L2 9L22 2Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>
        </div>

      </div>
    </div>
</div>

<script type="module" src="/assets/js/signal-modal.js"></script>
{% endmacro %}
