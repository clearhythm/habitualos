---
layout: base.njk
title: "Signal — Live Demo"
description: "Chat with Erik's Signal agent. Ask about his work, or paste a job description for a fit score."
showDemoModal: true
bodyClass: demo-page
---

<style>
  .demo-page {
    background: linear-gradient(to bottom, #130e28, #0a0d1a);
    min-height: 100dvh;
  }
  /* Hide nav and footer on demo page */
  .demo-page .signal-nav,
  .demo-page footer {
    display: none;
  }
</style>

<script>
(function () {
  function tryLaunch() {
    if (typeof window.Signal === 'object' && typeof window.Signal.launch === 'function') {
      window.Signal.launch({ mode: 'visitor', signalId: 'erik', redirectOnClose: '/' });
    } else {
      setTimeout(tryLaunch, 30);
    }
  }
  if (document.readyState !== 'loading') tryLaunch();
  else document.addEventListener('DOMContentLoaded', tryLaunch);
})();
</script>
