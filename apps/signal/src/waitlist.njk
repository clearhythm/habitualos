---
layout: base.njk
title: "Signal — Join the waitlist"
description: "Get early access to Signal — a professional fit-scoring agent trained on your actual AI work history."
---

<style>
  .waitlist-page {
    padding: 0 1.5rem;
    background: linear-gradient(to bottom, #130e28, #0a0d1a);
    height: calc(100dvh - 72px);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .waitlist-content-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    padding-bottom: 72px;
    position: relative;
    z-index: 1;
  }
  .waitlist-page-inner {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }
  .waitlist-headline {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 2rem;
    max-width: 600px;
  }
  .waitlist-body {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 3rem;
    align-items: start;
  }
  .waitlist-body .signal-pull-quote {
    border-left: none;
    padding: 0;
    font-size: 1.2rem;
    margin: 3.5rem 0 0;
  }
  @media (max-width: 640px) {
    .waitlist-body { grid-template-columns: 1fr; }
    .waitlist-body .signal-pull-quote {
      border-left: 3px solid #7c3aed;
      padding-left: 1.25rem;
      margin-top: 1rem;
    }
  }
  .waitlist-bg-img {
    display: block;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) scaleX(-1);
    width: 100%;
    max-width: 900px;
    opacity: 0.15;
    pointer-events: none;
    filter: invert(1);
    mix-blend-mode: screen;
  }
</style>

<div class="waitlist-page">
  <div class="waitlist-content-wrap">
  <div class="waitlist-page-inner">

    <h1 class="waitlist-headline">You've done the work.<br>Now let it speak.</h1>

    <div class="waitlist-body">

      <div>
        <div class="signal-qualify-block">
          <p class="signal-qualify-heading">Early access is for people who:</p>
          <ul class="signal-qualify-list">
            <li>Use Claude Code, Cursor, or Codex <em>near-daily</em></li>
            <li>Are actively job seeking or ready to make a move</li>
            <li>Are building real things, not just brainstorming</li>
          </ul>
          <p style="color: rgba(255,255,255,0.6);">If that describes you, I'll reach out directly with your free access code as space opens up.</p>
          <div id="waitlist-form-wrap">
            <form id="waitlist-form" class="signal-waitlist-form">
              <input
                type="email"
                id="waitlist-email"
                class="signal-waitlist-input"
                placeholder="your@email.com"
                required
                autocomplete="email"
              />
              <button type="submit" class="btn btn-primary" id="waitlist-submit">Request access</button>
            </form>
            <p id="waitlist-error" class="signal-waitlist-error" style="display:none"></p>
            <div id="waitlist-success" class="signal-waitlist-success" style="display:none">
              <p class="signal-waitlist-success-msg">You're on the list. You'll hear from Erik directly when your slot is ready.</p>
            </div>
          </div>
        </div>

        <p class="signal-waitlist-demo-link">Not sure yet? <a href="/demo/">See a live demo →</a></p>
      </div>

      <div>
        <blockquote class="signal-pull-quote">
          <p>&#8220;I built Signal because I was done polishing a version of myself instead of doing the work I love. Great work should speak for itself. Let&#8217;s create a better way to get discovered.&#8221;</p>
          <cite class="signal-pull-quote-cite">&mdash; <a href="https://erikburns.com" target="_blank" rel="noopener">Erik Burns</a>, creator of Signal</cite>
        </blockquote>
      </div>

    </div>
  </div>
  </div>
  <img src="/assets/images/signal_monkey_bg.png" alt="" class="waitlist-bg-img" aria-hidden="true">
</div>

<script>
(function() {
  var form = document.getElementById('waitlist-form');
  var emailEl = document.getElementById('waitlist-email');
  var submitBtn = document.getElementById('waitlist-submit');
  var errorEl = document.getElementById('waitlist-error');
  var formWrap = document.getElementById('waitlist-form-wrap');
  var successEl = document.getElementById('waitlist-success');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = emailEl.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    errorEl.style.display = 'none';

    try {
      var res = await fetch('/api/signal-waitlist', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email, context: 'article-launch' })
      });
      var data = await res.json();
      if (data.success) {
        formWrap.style.display = 'none';
        successEl.style.display = '';
      } else {
        throw new Error(data.error || 'Something went wrong');
      }
    } catch(err) {
      errorEl.textContent = err.message || 'Something went wrong. Try again.';
      errorEl.style.display = '';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Request access';
    }
  });
})();
</script>
