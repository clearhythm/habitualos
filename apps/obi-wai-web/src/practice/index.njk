---
title: Practice - HabitualOS
layout: base.njk
permalink: /practice/
pageScript: /assets/js/pages/practice-index.js
---

<div style="max-width: 800px; margin: 4rem auto; padding: 2rem; text-align: center;">
  <h1 id="rank-title"><span id="rank-emoji"></span> <span id="rank-name">&nbsp;</span></h1>
  <p style="font-size: 1.2rem; color: #666; margin: 0 0 2rem 0;" id="rank-subtitle">
    Loading...
  </p>

  <!-- Practice Action Cards -->
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin: 3rem 0 2.5rem 0;">
    <!-- Get Motivated Card -->
    <a href="/practice/chat/" style="text-decoration: none; color: inherit;">
      <div style="padding: 3rem 2rem; border: 2px solid #ddd; border-radius: 12px; transition: all 0.2s;"
           onmouseover="this.style.borderColor='#9b59b6'"
           onmouseout="this.style.borderColor='#ddd'">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🐉</div>
        <h2 style="margin: 0 0 1rem 0; font-size: 1.5rem;">Motivate</h2>
        <p style="color: #666; margin: 0;">Obi-Wai is here to help.<br/>Choose a practice, get motivated.</p>
      </div>
    </a>

    <!-- Log Practice Card -->
    <a href="/practice/log/" style="text-decoration: none; color: inherit;">
      <div style="padding: 3rem 2rem; border: 2px solid #ddd; border-radius: 12px; transition: all 0.2s;"
           onmouseover="this.style.borderColor='#0066cc'"
           onmouseout="this.style.borderColor='#ddd'">
        <div style="font-size: 3rem; margin-bottom: 1rem;">🪵</div>
        <h2 style="margin: 0 0 1rem 0; font-size: 1.5rem;">Log Practice</h2>
        <p style="color: #666; margin: 0;">Share what you did.<br/>Learn from what you share.</p>
      </div>
    </a>
  </div>

  <!-- Mobile responsive: Stack cards on small screens -->
  <style>
    @media (max-width: 600px) {
      div[style*="grid-template-columns: 1fr 1fr"] {
        grid-template-columns: 1fr !important;
      }
      div[style*="max-width: 800px"] {
        margin-top: 1rem !important;
      }
    }
    @media (min-width: 600px) {
      #march-challenge-block {
        display: inline-grid !important;
        grid-template-columns: auto auto;
        gap: 1.5rem 2rem;
        align-items: start;
      }
      #march-challenge-left {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      #selected-day-actions {
        justify-content: center !important;
      }
      #march-challenge-block .day-nav {
        justify-content: center !important;
      }
      #challenge-streak-label {
        grid-column: 1 / -1;
        margin-top: 0 !important;
      }
    }
  </style>

  <!-- March Challenge Widget -->
  <div id="march-challenge-block" style="margin-top: 1.5rem; display: none; text-align: center;">

    <!-- Left: title + navigator + buttons + streak -->
    <div id="march-challenge-left">
      <!-- Static title -->
      <h2 style="font-size: 1.25rem; font-weight: 600; margin: 0 0 0.25rem 0;">March Challenge</h2>

      <!-- Day navigator -->
      <div class="day-nav" style="display: flex; align-items: center; justify-content: center; gap: 0.25rem; margin-top: 0.75rem; margin-bottom: 1rem;">
        <button id="prev-day-btn" style="background: none; border: none; font-size: 1.4rem; cursor: pointer; color: #bbb; padding: 0 0.4rem; line-height: 1;">‹</button>
        <h3 id="selected-day-label" style="font-size: 1rem; font-weight: 600; margin: 0; min-width: 7rem;"></h3>
        <button id="next-day-btn" style="background: none; border: none; font-size: 1.4rem; cursor: pointer; color: #bbb; padding: 0 0.4rem; line-height: 1;">›</button>
      </div>

      <!-- Log buttons -->
      <div id="selected-day-actions" style="display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 0.75rem;">
        <a id="log-jogging-link" href="/practice/log/?prefill=Jogging" data-label="Jogging" data-emoji="🏃" data-done-icon="◐"
           style="padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.85rem; text-decoration: none; border: 1.5px solid #555; color: #555;">🏃 Jogging</a>
        <a id="log-lasso-link" href="/practice/log/?prefill=LASSO" data-label="LASSO" data-emoji="🧘" data-done-icon="◑"
           style="padding: 0.5rem 1rem; border-radius: 6px; font-size: 0.85rem; text-decoration: none; border: 1.5px solid #555; color: #555;">🧘 LASSO</a>
      </div>

    </div>

    <!-- Right: Calendar grid -->
    <div id="home-calendar" style="display: grid; grid-template-columns: repeat(7, 26px); gap: 5px; justify-content: center;"></div>

    <!-- Streak: below buttons on mobile, spans both columns on desktop -->
    <p id="challenge-streak-label" style="font-size: 0.9rem; color: #999; margin: 1.25rem 0 0 0;"></p>
  </div>
</div>
