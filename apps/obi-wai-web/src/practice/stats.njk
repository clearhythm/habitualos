---
title: Stats - HabitualOS
layout: base.njk
permalink: /practice/stats/
pageScript: /assets/js/pages/practice-stats.js
---

<div style="max-width: 800px; margin: 4rem auto; padding: 2rem; text-align: center;">
  <h1 id="rank-title"><span id="rank-emoji"></span> <span id="rank-name">&nbsp;</span></h1>
  <p style="font-size: 1.2rem; color: #666; margin: 0 0 2rem 0;" id="rank-subtitle">
    Loading...
  </p>

  <style>
    html[data-theme="dark"] .habits-title {
      color: #e5e7eb;
    }
    html[data-theme="dark"] .stat-number {
      color: #e5e7eb !important;
    }
    html[data-theme="dark"] .stat-label {
      color: #9ca3af !important;
    }
    html[data-theme="dark"] .stat-link {
      color: #60a5fa !important;
    }
    html[data-theme="dark"] .stat-divider {
      background: #374151 !important;
    }
  </style>

  <h2 class="habits-title" style="margin-top: 3rem; margin-bottom: 1rem; font-size: 1.25rem;">Your Habits</h2>
  <div class="habits-stats" style="display: grid; grid-template-columns: 1fr auto 1fr; gap: 1rem; align-items: center; padding: 2rem 1rem; border-radius: 8px;">
    <a href="/practice/history/" style="text-decoration: none; text-align: center; color: inherit;">
      <div class="stat-number" style="font-size: 2rem; font-weight: 600; color: #333; margin-bottom: 0.25rem;" id="checkins-count">--</div>
      <div class="stat-label" style="font-size: 0.9rem; color: #666; margin-bottom: 0.5rem;">check-ins</div>
      <div class="stat-link" style="font-size: 0.85rem; color: #0066cc; text-decoration: underline;">view &gt;</div>
    </a>
    <div class="stat-divider" style="width: 1px; height: 60px; background: #ddd;"></div>
    <a href="/practice/library/" style="text-decoration: none; text-align: center; color: inherit;">
      <div class="stat-number" style="font-size: 2rem; font-weight: 600; color: #333; margin-bottom: 0.25rem;" id="practices-count">--</div>
      <div class="stat-label" style="font-size: 0.9rem; color: #666; margin-bottom: 0.5rem;">practices</div>
      <div class="stat-link" style="font-size: 0.85rem; color: #0066cc; text-decoration: underline;">view &gt;</div>
    </a>
  </div>

  <!-- March Challenge -->
  <div id="challenge-block" style="display: none; margin-top: 3rem; text-align: left;">
    <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.25rem;">
      <h2 style="font-size: 1.25rem; margin: 0;">March Challenge</h2>
      <div style="font-size: 0.9rem; color: #999;" id="challenge-meta"></div>
    </div>

    <div style="margin-bottom: 1.25rem;">
      <div style="margin-bottom: 0.75rem; display: flex; align-items: center; gap: 0.75rem;">
        <span style="font-size: 1.1rem;">🏃 Jogging</span>
        <span id="goal-jogging-status" style="color: #999;">○ not yet</span>
      </div>
      <div style="display: flex; align-items: center; gap: 0.75rem;">
        <span style="font-size: 1.1rem;">🧘 LASSO</span>
        <span id="goal-lasso-status" style="color: #999;">○ not yet</span>
      </div>
    </div>

    <div id="checkin-block" style="margin-bottom: 1.25rem; display: none;"></div>
    <div id="checkin-pending" style="margin-bottom: 1.25rem; display: none;">
      <a href="/practice/chat/" style="font-size: 0.9rem; color: #9b59b6; text-decoration: none;">+ Daily check-in not done yet →</a>
    </div>

    <div id="challenge-calendar" style="display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 1rem;"></div>

    <div style="font-size: 0.8rem; color: #bbb; display: flex; gap: 1rem; flex-wrap: wrap;">
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#4d9618;"></span> complete</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#9ab845;"></span> partial</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#f39c12;"></span> missed</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#3498db;"></span> today</span>
      <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:#f0f0f0;"></span> future</span>
    </div>
  </div>
</div>
