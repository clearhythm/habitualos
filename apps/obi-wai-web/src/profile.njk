<div style="max-width: 600px; margin: 4rem auto; padding: 2rem;">
  <h1 style="margin-bottom: 0.5rem;">Profile</h1>
  <p style="color: #666; margin-bottom: 2rem;">Register your phone number so Obi-Wai can text you a reminder at 7pm if you haven't checked in.</p>

  <form id="profile-form" style="display: flex; flex-direction: column; gap: 1rem;">
    <div>
      <label for="phone-input" style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Phone number</label>
      <input
        type="tel"
        id="phone-input"
        placeholder="(555) 555-5555"
        style="width: 100%; padding: 0.75rem 1rem; border: 2px solid #ddd; border-radius: 8px; font-size: 1rem; box-sizing: border-box;"
      />
      <p style="font-size: 0.85rem; color: #999; margin: 0.4rem 0 0;">US numbers only. Standard SMS rates apply.</p>
    </div>

    <button type="submit" id="save-btn" class="btn btn-primary" style="align-self: flex-start;">
      Save
    </button>

    <p id="status-msg" style="display: none; padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.95rem;"></p>
  </form>
</div>
