---
title: Sign In - Obi-Wai
layout: base.njk
permalink: /signin/
pageScript: /assets/js/signin.js
---

<div style="max-width: 420px; margin: 4rem auto; padding: 2rem; text-align: center;">

  <!-- STATE 0: Already signed in -->
  <div id="already-signed-in" style="display: none;">
    <h2>Welcome back</h2>
    <p>You're signed in as <strong id="signedInName"></strong>.</p>
    <p><a href="/practice/">Go to practice</a></p>
    <p style="margin-top: 2rem;"><a href="/signout/">Sign out</a></p>
  </div>

  <!-- STATE 1: Sign in form -->
  <div id="signin-form" style="display: none;">
    <h2>Sign in</h2>
    <p style="color: #666; margin-bottom: 2rem;">Enter your email and we'll send you a sign-in link.</p>

    <input id="emailInput" type="email" placeholder="Your email..."
           style="width: 100%; padding: 0.75rem; font-size: 1rem; border: 2px solid #ddd; border-radius: 8px; box-sizing: border-box;">

    <div id="errorMsg" style="display: none; color: #a00; margin-top: 0.5rem; font-size: 0.9rem;"></div>

    <button id="signInBtn" class="btn btn-primary"
            style="margin-top: 1.5rem; width: 100%;">
      Send sign-in link
    </button>
  </div>

  <!-- STATE 2: Check your email -->
  <div id="email-sent" style="display: none;">
    <div style="font-size: 3rem; margin-bottom: 1rem;">📬</div>
    <h2>Check your email</h2>
    <p style="color: #666;">We sent a sign-in link to <strong id="sentToEmail"></strong>.</p>
    <p style="color: #888; font-size: 0.9rem; margin-top: 1rem;">Link expires in 15 minutes. Check your spam folder if you don't see it.</p>
  </div>

</div>
