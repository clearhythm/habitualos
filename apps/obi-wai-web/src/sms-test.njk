---
title: SMS Test - HabitualOS
layout: base.njk
permalink: /sms-test/
---

<div style="max-width: 600px; margin: 4rem auto; padding: 2rem;">
  <h1 style="margin-bottom: 0.5rem;">SMS Test Console</h1>
  <p style="color: #666; margin-bottom: 2rem;">Simulate inbound messages and send test SMS. Requires <code>SMS_TEST_SECRET</code> env var if set.</p>

  <div style="margin-bottom: 1.5rem;">
    <label style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Secret (if required)</label>
    <input id="secret" type="password" placeholder="SMS_TEST_SECRET value" style="width: 100%; padding: 0.6rem 0.8rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box;" />
  </div>

  <div style="margin-bottom: 1.5rem;">
    <label style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Phone number (E.164)</label>
    <input id="phone" type="tel" placeholder="+15551234567" style="width: 100%; padding: 0.6rem 0.8rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box;" />
  </div>

  <!-- Inbound simulation -->
  <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 1.25rem; margin-bottom: 1.25rem;">
    <h3 style="margin: 0 0 1rem; font-size: 1rem;">Simulate inbound SMS</h3>
    <p style="color: #666; font-size: 0.875rem; margin: 0 0 0.75rem;">Runs the full inbound logic: practice detection, logging, or Obi-Wai coaching. Sends reply back via Twilio.</p>
    <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem;">
      <button onclick="setMsg('jogged 10 min')" style="padding: 0.3rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; background: #f5f5f5; cursor: pointer; font-size: 0.875rem;">jogged 10 min</button>
      <button onclick="setMsg('did lasso for 5 minutes')" style="padding: 0.3rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; background: #f5f5f5; cursor: pointer; font-size: 0.875rem;">lasso 5 min</button>
      <button onclick="setMsg('ran and did lasso today')" style="padding: 0.3rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; background: #f5f5f5; cursor: pointer; font-size: 0.875rem;">both (jogged + lasso)</button>
      <button onclick="setMsg('not feeling it today')" style="padding: 0.3rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; background: #f5f5f5; cursor: pointer; font-size: 0.875rem;">coaching: "not feeling it"</button>
      <button onclick="setMsg('I keep skipping, help')" style="padding: 0.3rem 0.75rem; border: 1px solid #ccc; border-radius: 4px; background: #f5f5f5; cursor: pointer; font-size: 0.875rem;">coaching: skipping</button>
    </div>
    <textarea id="inbound-message" placeholder="Message body..." rows="2" style="width: 100%; padding: 0.6rem 0.8rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box; resize: vertical;"></textarea>
    <button onclick="sendInbound()" style="margin-top: 0.75rem; padding: 0.6rem 1.25rem; background: #0066cc; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 0.95rem;">Send inbound</button>
  </div>

  <!-- Reminder test -->
  <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 1.25rem; margin-bottom: 1.25rem;">
    <h3 style="margin: 0 0 0.5rem; font-size: 1rem;">Send test reminder</h3>
    <p style="color: #666; font-size: 0.875rem; margin: 0 0 0.75rem;">Looks up user by phone, checks today's challenge status, sends reminder if not complete.</p>
    <button onclick="sendReminder()" style="padding: 0.6rem 1.25rem; background: #e67e22; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 0.95rem;">Send reminder</button>
  </div>

  <!-- Custom outbound -->
  <div style="border: 1px solid #e0e0e0; border-radius: 8px; padding: 1.25rem; margin-bottom: 1.25rem;">
    <h3 style="margin: 0 0 0.5rem; font-size: 1rem;">Send custom SMS</h3>
    <p style="color: #666; font-size: 0.875rem; margin: 0 0 0.75rem;">Send any arbitrary message to the phone number via Twilio.</p>
    <textarea id="custom-message" placeholder="Custom message..." rows="2" style="width: 100%; padding: 0.6rem 0.8rem; border: 1px solid #ddd; border-radius: 6px; font-size: 0.95rem; box-sizing: border-box; resize: vertical;"></textarea>
    <button onclick="sendCustom()" style="margin-top: 0.75rem; padding: 0.6rem 1.25rem; background: #27ae60; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 0.95rem;">Send SMS</button>
  </div>

  <!-- Output -->
  <div id="output" style="display: none; padding: 1rem; border-radius: 8px; background: #f5f5f5; font-family: monospace; font-size: 0.875rem; white-space: pre-wrap; word-break: break-word;"></div>
</div>

<script>
  function setMsg(text) {
    document.getElementById('inbound-message').value = text;
  }

  function getInputs() {
    return {
      secret: document.getElementById('secret').value,
      phone: document.getElementById('phone').value.trim()
    };
  }

  function showOutput(data, isError) {
    const el = document.getElementById('output');
    el.style.display = 'block';
    el.style.background = isError ? '#fce4e4' : '#f5f5f5';
    el.textContent = JSON.stringify(data, null, 2);
  }

  async function post(body) {
    const res = await fetch('/api/sms-test', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    return res.json();
  }

  async function sendInbound() {
    const { secret, phone } = getInputs();
    const message = document.getElementById('inbound-message').value.trim();
    if (!phone || !message) { showOutput({ error: 'phone and message required' }, true); return; }
    try {
      const result = await post({ secret, type: 'inbound', phone, message });
      showOutput(result, !!result.error);
    } catch (e) {
      showOutput({ error: e.message }, true);
    }
  }

  async function sendReminder() {
    const { secret, phone } = getInputs();
    if (!phone) { showOutput({ error: 'phone required' }, true); return; }
    try {
      const result = await post({ secret, type: 'reminder', phone });
      showOutput(result, !!result.error);
    } catch (e) {
      showOutput({ error: e.message }, true);
    }
  }

  async function sendCustom() {
    const { secret, phone } = getInputs();
    const message = document.getElementById('custom-message').value.trim();
    if (!phone || !message) { showOutput({ error: 'phone and message required' }, true); return; }
    try {
      const result = await post({ secret, type: 'send', phone, message });
      showOutput(result, !!result.error);
    } catch (e) {
      showOutput({ error: e.message }, true);
    }
  }
</script>
